<Window x:Class="InteractiveMask.Display.PinDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PIN"
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        ResizeMode="NoResize"
        Background="#1A1A1A"
        Foreground="White"
        FontFamily="Segoe UI"
        Topmost="True"
        ShowInTaskbar="False"
        KeyDown="OnKeyDown">

    <Border BorderBrush="#404040" BorderThickness="1" Padding="28">
        <StackPanel Width="320">
            <TextBlock x:Name="Header"
                       Text="Stel sessie-PIN in"
                       FontSize="18"
                       FontWeight="SemiBold"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,4" />
            <TextBlock x:Name="Subheader"
                       Text="4 cijfers"
                       FontSize="13"
                       Foreground="#A0A0A0"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,18" />

            <!-- 4 dots showing how many digits have been entered -->
            <StackPanel x:Name="DotsRow"
                        Orientation="Horizontal"
                        HorizontalAlignment="Center"
                        Margin="0,0,0,8">
                <Ellipse x:Name="Dot0" Width="16" Height="16" Margin="6" Stroke="#808080" StrokeThickness="2" Fill="Transparent" />
                <Ellipse x:Name="Dot1" Width="16" Height="16" Margin="6" Stroke="#808080" StrokeThickness="2" Fill="Transparent" />
                <Ellipse x:Name="Dot2" Width="16" Height="16" Margin="6" Stroke="#808080" StrokeThickness="2" Fill="Transparent" />
                <Ellipse x:Name="Dot3" Width="16" Height="16" Margin="6" Stroke="#808080" StrokeThickness="2" Fill="Transparent" />
            </StackPanel>

            <TextBlock x:Name="ErrorText"
                       Foreground="#FF7777"
                       FontSize="13"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,12"
                       Text="" />

            <!-- 3x4 keypad: 1..9, 0, backspace -->
            <UniformGrid Rows="4" Columns="3" Margin="0,0,0,8">
                <Button Content="1" Tag="1" Click="OnDigitClick" />
                <Button Content="2" Tag="2" Click="OnDigitClick" />
                <Button Content="3" Tag="3" Click="OnDigitClick" />
                <Button Content="4" Tag="4" Click="OnDigitClick" />
                <Button Content="5" Tag="5" Click="OnDigitClick" />
                <Button Content="6" Tag="6" Click="OnDigitClick" />
                <Button Content="7" Tag="7" Click="OnDigitClick" />
                <Button Content="8" Tag="8" Click="OnDigitClick" />
                <Button Content="9" Tag="9" Click="OnDigitClick" />
                <Button Content="" />
                <Button Content="0" Tag="0" Click="OnDigitClick" />
                <Button Content="←" Click="OnBackspaceClick" />
                <UniformGrid.Resources>
                    <Style TargetType="Button">
                        <Setter Property="Margin" Value="4" />
                        <Setter Property="Height" Value="56" />
                        <Setter Property="FontSize" Value="22" />
                        <Setter Property="Background" Value="#2A2A2A" />
                        <Setter Property="Foreground" Value="White" />
                        <Setter Property="BorderBrush" Value="#404040" />
                        <Setter Property="BorderThickness" Value="1" />
                        <Setter Property="Cursor" Value="Hand" />
                    </Style>
                </UniformGrid.Resources>
            </UniformGrid>

            <Button x:Name="CancelButton"
                    Content="Annuleer"
                    Height="36"
                    Margin="0,8,0,0"
                    Background="Transparent"
                    Foreground="#A0A0A0"
                    BorderThickness="0"
                    Cursor="Hand"
                    Click="OnCancelClick" />
        </StackPanel>
    </Border>
</Window>
