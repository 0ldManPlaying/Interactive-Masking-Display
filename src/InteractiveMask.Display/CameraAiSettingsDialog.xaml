<Window x:Class="InteractiveMask.Display.CameraAiSettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:InteractiveMask.Display"
        Title="AI"
        Icon="pack://application:,,,/app.ico"
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        Topmost="True"
        ShowInTaskbar="False"
        FontFamily="Segoe UI Variable Display, Segoe UI"
        Foreground="#E6E6E6"
        KeyDown="OnKeyDown">

    <Window.Resources>
        <!-- Default styling so checkbox labels keep their light-on-dark contrast.
             WPF's default Foreground inherits SystemColors.ControlText (black) and
             becomes unreadable on this dialog's dark chrome without an explicit
             setter. Same lesson as the Setup window from v1.3. -->
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#E6E6E6" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
    </Window.Resources>

    <Border Background="#1A1D24"
            BorderBrush="#2A2F3A"
            BorderThickness="1"
            CornerRadius="14"
            Padding="28"
            MinWidth="420">
        <Border.Effect>
            <DropShadowEffect Color="Black" BlurRadius="22" ShadowDepth="0" Opacity="0.5" />
        </Border.Effect>
        <StackPanel>
            <TextBlock Text="{local:Loc AiDialogTitle}"
                       FontSize="18"
                       FontWeight="SemiBold"
                       HorizontalAlignment="Center" />
            <TextBlock x:Name="SubheaderText"
                       Foreground="#8B95A7"
                       FontSize="13"
                       HorizontalAlignment="Center"
                       Margin="0,4,0,20" />

            <!-- Master toggle. When unchecked the categories are visually dimmed
                 and ignored on Save, but their state is kept in the UI so flipping
                 the master back on restores the prior selection (not surprising). -->
            <CheckBox x:Name="EnableBox"
                      Content="{local:Loc AiEnableToggle}"
                      FontWeight="SemiBold"
                      FontSize="14"
                      Checked="OnEnableChanged"
                      Unchecked="OnEnableChanged" />

            <TextBlock Text="{local:Loc AiClassesHeader}"
                       Foreground="#8B95A7"
                       FontSize="12"
                       Margin="0,18,0,8" />

            <StackPanel x:Name="ClassesPanel" Margin="6,0,0,0">
                <CheckBox x:Name="PersonBox"
                          Content="{local:Loc AiClassPerson}"
                          Margin="0,4,0,4" />
                <CheckBox x:Name="TwoWheelerBox"
                          Content="{local:Loc AiClassTwoWheeler}"
                          Margin="0,4,0,4" />
                <CheckBox x:Name="VehicleBox"
                          Content="{local:Loc AiClassVehicle}"
                          Margin="0,4,0,4" />
            </StackPanel>

            <!-- Mask padding: inflates the blur region around each detection. -->
            <Grid Margin="0,20,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="56" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="{local:Loc AiPaddingHeader}"
                           Foreground="#8B95A7"
                           FontSize="12"
                           VerticalAlignment="Center" />
                <TextBlock Grid.Column="1"
                           x:Name="PaddingValueText"
                           Foreground="#E6E6E6"
                           FontSize="13"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Center" />
            </Grid>
            <Slider x:Name="PaddingSlider"
                    Minimum="0" Maximum="50"
                    SmallChange="1" LargeChange="5"
                    TickFrequency="5" TickPlacement="None"
                    IsSnapToTickEnabled="False"
                    Margin="0,6,0,0"
                    ValueChanged="OnPaddingSliderChanged" />

            <TextBlock Foreground="#8B95A7" FontSize="11" TextWrapping="Wrap"
                       Margin="0,16,0,0"
                       Text="{local:Loc AiDialogHint}" />

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,22,0,0">
                <Button Content="{local:Loc SetupCancel}"
                        Click="OnCancel"
                        Background="Transparent" Foreground="#8B95A7"
                        BorderBrush="#374050" BorderThickness="1"
                        Padding="14,8" Cursor="Hand"
                        Margin="0,0,8,0" />
                <Button Content="{local:Loc SetupSave}"
                        Click="OnOk"
                        IsDefault="True"
                        Background="#4DABF7" Foreground="#0F1115"
                        FontWeight="SemiBold"
                        BorderThickness="0"
                        Padding="14,8" Cursor="Hand" />
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
