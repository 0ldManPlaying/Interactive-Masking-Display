<Window x:Class="InteractiveMask.Display.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:InteractiveMask.Display"
        Title="InteractiveMask"
        Icon="pack://application:,,,/app.ico"
        Width="1280" Height="720"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"
        Background="Black"
        WindowStyle="None"
        ResizeMode="NoResize"
        Loaded="OnLoaded"
        Closing="OnClosing"
        KeyDown="OnKeyDown"
        PreviewMouseRightButtonUp="OnContextMenuRequested">

    <Window.Resources>
        <!-- Converters must be declared BEFORE any template that references them via
             StaticResource; WPF resolves StaticResource at parse time and cannot
             handle forward references. -->
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <local:BoundingBoxToViewboxConverter x:Key="BoxToViewbox" />

        <DataTemplate DataType="{x:Type local:TileViewModel}">
            <!-- Background must be solid (not Transparent) for hit-testing to fire
                 the click handler reliably across the whole tile.
                 Tap fires on MouseLeftButtonUp (not Down) so the global long-press
                 gesture in MainWindow can intercept first; without that split a
                 long-press would always toggle the tile under the finger. -->
            <Grid Background="#1A1A1A"
                  Margin="2"
                  MouseLeftButtonUp="OnTileTapped">

                <!-- Live image. Stretch=Uniform (fit) preserves the camera's
                     native aspect ratio. Cameras whose ratio doesn't match the
                     tile (4:3, 5:4, 1:1 fish-eye, 21:9, etc.) letterbox / pillar-
                     box against the dark tile background instead of being cropped
                     by UniformToFill, which silently lost edge content.

                     The BlurEffect is only attached when IsMasked=true; leaving
                     an Effect on every tile (even with Radius=0) costs the GPU
                     an intermediate render target per tile per frame, which is
                     heavy for 16 tiles at 25 fps. -->
                <Image Source="{Binding Bitmap}"
                       Stretch="Uniform"
                       RenderOptions.BitmapScalingMode="LowQuality">
                    <Image.Style>
                        <Style TargetType="Image">
                            <Setter Property="Effect" Value="{x:Null}" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsMasked}" Value="True">
                                    <Setter Property="Effect">
                                        <Setter.Value>
                                            <BlurEffect Radius="80"
                                                        KernelType="Gaussian"
                                                        RenderingBias="Performance" />
                                        </Setter.Value>
                                    </Setter>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Image.Style>
                </Image>

                <!-- v2.0 AI detection overlay. Viewbox letterboxes the inner Grid the
                     same way Stretch=Uniform letterboxes the Image above, so detections
                     in source-frame pixel coordinates land exactly on the rendered
                     pixels. Hidden while IsMasked=True (full-tile blur supersedes any
                     per-detection overlay) and ignores hit-testing so taps reach the
                     Image's MouseLeftButtonUp handler unobstructed.

                     The inner Rectangle is a placeholder visual for M3 v0.1; M3.1
                     will replace it with a VisualBrush sample of the underlying Image
                     plus a BlurEffect to deliver real per-region blur. -->
                <Viewbox Stretch="Uniform" IsHitTestVisible="False">
                    <Viewbox.Style>
                        <Style TargetType="Viewbox">
                            <Setter Property="Visibility" Value="Visible" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsMasked}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Viewbox.Style>
                    <Grid Width="{Binding Bitmap.PixelWidth, FallbackValue=1}"
                          Height="{Binding Bitmap.PixelHeight, FallbackValue=1}">
                        <ItemsControl ItemsSource="{Binding Detections}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <Canvas />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemContainerStyle>
                                <Style TargetType="ContentPresenter">
                                    <Setter Property="Canvas.Left" Value="{Binding Box.X}" />
                                    <Setter Property="Canvas.Top" Value="{Binding Box.Y}" />
                                </Style>
                            </ItemsControl.ItemContainerStyle>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <!-- Real per-region blur. The ImageBrush samples the
                                         detection's pixel rectangle out of the tile's
                                         WriteableBitmap (Viewbox in absolute pixel units)
                                         and renders it onto a same-sized Rectangle. The
                                         BlurEffect on top scrambles the sampled pixels so
                                         features are no longer recognizable while colour /
                                         brightness silhouettes remain. The ImageSource is
                                         pulled from the parent TileViewModel via the
                                         ItemsControl's DataContext; per-item DataContext
                                         is a DetectedObject. -->
                                    <Rectangle Width="{Binding Box.Width}"
                                               Height="{Binding Box.Height}">
                                        <Rectangle.Fill>
                                            <ImageBrush
                                                ImageSource="{Binding DataContext.Bitmap, RelativeSource={RelativeSource AncestorType={x:Type ItemsControl}}}"
                                                ViewboxUnits="Absolute"
                                                Stretch="Fill">
                                                <ImageBrush.Viewbox>
                                                    <MultiBinding Converter="{StaticResource BoxToViewbox}">
                                                        <Binding Path="Box.X" />
                                                        <Binding Path="Box.Y" />
                                                        <Binding Path="Box.Width" />
                                                        <Binding Path="Box.Height" />
                                                    </MultiBinding>
                                                </ImageBrush.Viewbox>
                                            </ImageBrush>
                                        </Rectangle.Fill>
                                        <Rectangle.Effect>
                                            <BlurEffect Radius="25"
                                                        KernelType="Gaussian"
                                                        RenderingBias="Performance" />
                                        </Rectangle.Effect>
                                    </Rectangle>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>
                </Viewbox>

                <!-- Privacy overlay shown when masked: a translucent dim layer plus
                     the "Privacy actief - {Label}" text and (when armed) the
                     auto-unmask countdown. Centered so it's the first thing a
                     caregiver glancing at the screen will read. -->
                <Grid Visibility="{Binding IsMasked, Converter={StaticResource BoolToVis}}"
                      Background="#60000000"
                      IsHitTestVisible="False">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="{Binding MaskOverlayText}"
                                   Foreground="White"
                                   FontFamily="Segoe UI"
                                   FontSize="22"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Center"
                                   TextAlignment="Center" />
                        <TextBlock Text="{Binding CountdownText}"
                                   Foreground="#FFB347"
                                   FontFamily="Segoe UI"
                                   FontSize="22"
                                   FontWeight="SemiBold"
                                   Margin="0,8,0,0"
                                   HorizontalAlignment="Center"
                                   TextAlignment="Center" />
                    </StackPanel>
                </Grid>

                <!-- Empty tile placeholder when no camera is bound:
                     subtle IDIS watermark (10% opacity) plus an "no camera"
                     label underneath. The whole stack is hidden as soon as a
                     camera is bound to this slot. -->
                <StackPanel HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Orientation="Vertical">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasCamera}" Value="False">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <Image Source="pack://application:,,,/idis-logo-mask.png"
                           Opacity="0.10"
                           Stretch="Uniform"
                           MaxWidth="240"
                           MaxHeight="120"
                           SnapsToDevicePixels="True"
                           RenderOptions.BitmapScalingMode="HighQuality" />
                    <TextBlock Text="{Binding Source={x:Static local:Strings.Instance}, Path=Current.EmptyTile}"
                               Foreground="#404040"
                               FontFamily="Segoe UI"
                               FontSize="14"
                               HorizontalAlignment="Center"
                               Margin="0,12,0,0" />
                </StackPanel>

                <!-- Bottom status bar.
                     Left:  status dot + NVR-side camera title + status text.
                     Right: operator label + privacy badge.
                     Both texts toggle independently from Setup > Privacy >
                     Tile overlay. Status dot and privacy badge always show. -->
                <Border VerticalAlignment="Bottom"
                        HorizontalAlignment="Stretch"
                        Background="#80000000"
                        Padding="6,3"
                        Visibility="{Binding HasCamera, Converter={StaticResource BoolToVis}}">
                    <Grid>
                        <!-- Left cluster -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                            <Ellipse Width="8" Height="8"
                                     Fill="{Binding StatusBrush}"
                                     VerticalAlignment="Center"
                                     Margin="0,0,6,0" />
                            <TextBlock Text="{Binding NvrTitle}"
                                       Foreground="White"
                                       FontFamily="Segoe UI"
                                       FontSize="12"
                                       VerticalAlignment="Center"
                                       Visibility="{Binding IsNvrTitleVisible, Converter={StaticResource BoolToVis}}" />
                            <TextBlock Text="{Binding StatusText}"
                                       Foreground="#FFCC66"
                                       FontFamily="Segoe UI"
                                       FontSize="12"
                                       Margin="8,0,0,0"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                        <!-- Right cluster -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <TextBlock Text="{Binding Label}"
                                       Foreground="White"
                                       FontFamily="Segoe UI"
                                       FontSize="12"
                                       VerticalAlignment="Center"
                                       Visibility="{Binding IsLabelVisible, Converter={StaticResource BoolToVis}}" />
                            <TextBlock Text="{Binding Source={x:Static local:Strings.Instance}, Path=Current.PrivacyBadge}"
                                       Foreground="#FF7777"
                                       FontFamily="Segoe UI"
                                       FontSize="12"
                                       FontWeight="Bold"
                                       Margin="8,0,0,0"
                                       VerticalAlignment="Center"
                                       Visibility="{Binding IsMasked, Converter={StaticResource BoolToVis}}" />
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Warning border: pulses orange in the final WarningMinutes minutes
                     before auto-unmask so a caregiver notices the mask is about to lift. -->
                <Border BorderBrush="#FFB347"
                        BorderThickness="3"
                        IsHitTestVisible="False">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsTimerWarning}" Value="True">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <DataTrigger.EnterActions>
                                        <BeginStoryboard Name="WarnPulseSb">
                                            <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                 From="1.0" To="0.25" Duration="0:0:0.7" />
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </DataTrigger.EnterActions>
                                    <DataTrigger.ExitActions>
                                        <StopStoryboard BeginStoryboardName="WarnPulseSb" />
                                    </DataTrigger.ExitActions>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                </Border>
            </Grid>
        </DataTemplate>
    </Window.Resources>

    <Grid Background="Transparent"
          PreviewMouseLeftButtonDown="OnRootMouseDown"
          PreviewMouseLeftButtonUp="OnRootMouseUp"
          PreviewMouseMove="OnRootMouseMove">
        <ItemsControl x:Name="TilesHost" ItemsSource="{Binding Tiles}">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <UniformGrid Rows="{Binding Rows}" Columns="{Binding Columns}" />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
        </ItemsControl>

        <TextBlock x:Name="StatusBar"
                   Text="{Binding StatusLine}"
                   Foreground="#80FFFFFF"
                   FontFamily="Consolas"
                   FontSize="12"
                   Margin="8,4"
                   VerticalAlignment="Top"
                   HorizontalAlignment="Left" />


        <!-- Reconnect banner: pulses orange while the NVR session is down, with
             a live-ticking countdown until the next reconnect attempt. Centered
             at the top so a caregiver sees it from across the room. -->
        <Border HorizontalAlignment="Center"
                VerticalAlignment="Top"
                Margin="0,12,0,0"
                Padding="18,10"
                Background="#E61A1D24"
                BorderBrush="#FFB347"
                BorderThickness="1"
                CornerRadius="10"
                IsHitTestVisible="False"
                Visibility="{Binding ConnectionLost, Converter={StaticResource BoolToVis}}">
            <Border.Effect>
                <DropShadowEffect BlurRadius="14" Opacity="0.55" ShadowDepth="0" />
            </Border.Effect>
            <StackPanel Orientation="Horizontal">
                <Ellipse Width="12" Height="12"
                         Fill="#FFB347"
                         VerticalAlignment="Center"
                         Margin="0,0,10,0">
                    <Ellipse.Style>
                        <Style TargetType="Ellipse">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ConnectionLost}" Value="True">
                                    <DataTrigger.EnterActions>
                                        <BeginStoryboard Name="ReconnectPulseSb">
                                            <Storyboard RepeatBehavior="Forever" AutoReverse="True">
                                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                 From="1.0" To="0.3"
                                                                 Duration="0:0:0.8" />
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </DataTrigger.EnterActions>
                                    <DataTrigger.ExitActions>
                                        <StopStoryboard BeginStoryboardName="ReconnectPulseSb" />
                                    </DataTrigger.ExitActions>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Ellipse.Style>
                </Ellipse>
                <TextBlock Text="{Binding ConnectionBanner}"
                           Foreground="#FFB347"
                           FontFamily="Segoe UI"
                           FontSize="15"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
