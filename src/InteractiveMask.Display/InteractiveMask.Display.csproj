<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <UseWPF>true</UseWPF>
    <RootNamespace>InteractiveMask.Display</RootNamespace>
    <AssemblyName>InteractiveMask.Display</AssemblyName>
    <ApplicationManifest>app.manifest</ApplicationManifest>
    <ApplicationIcon>app.ico</ApplicationIcon>
    <Version>1.0.1</Version>
    <FileVersion>1.0.1.0</FileVersion>
    <AssemblyVersion>1.0.1.0</AssemblyVersion>
    <Product>InteractiveMask</Product>
    <Company>InteractiveMask</Company>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\InteractiveMask.Gdk\InteractiveMask.Gdk.csproj" />
    <ProjectReference Include="..\InteractiveMask.Ipc\InteractiveMask.Ipc.csproj" />
  </ItemGroup>

  <!-- ApplicationIcon sets only the EXE/window chrome icon. Adding the same
       file as a WPF Resource makes it reachable via pack://application:,,,/app.ico
       so per-Window Icon="..." bindings actually resolve at runtime. -->
  <ItemGroup>
    <Resource Include="app.ico" />
  </ItemGroup>

  <ItemGroup>
    <None Update="appsettings.json">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
    <None Update="appsettings.Local.json" Condition="Exists('appsettings.Local.json')">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.Configuration" Version="9.0.0" />
    <PackageReference Include="Microsoft.Extensions.Configuration.Json" Version="9.0.0" />
    <PackageReference Include="Microsoft.Extensions.Configuration.Binder" Version="9.0.0" />
    <PackageReference Include="System.Security.Cryptography.ProtectedData" Version="9.0.0" />
  </ItemGroup>

</Project>
