<Window x:Class="InteractiveMask.Display.RoiEditorDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:InteractiveMask.Display"
        Title="ROI"
        Icon="pack://application:,,,/app.ico"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        Topmost="True"
        ShowInTaskbar="False"
        FontFamily="Segoe UI Variable Display, Segoe UI"
        Foreground="#E6E6E6"
        KeyDown="OnKeyDown"
        Width="1000" Height="720">

    <Border Background="#1A1D24"
            BorderBrush="#2A2F3A"
            BorderThickness="1"
            CornerRadius="14"
            Padding="24">
        <Border.Effect>
            <DropShadowEffect Color="Black" BlurRadius="22" ShadowDepth="0" Opacity="0.5" />
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Header -->
            <TextBlock Grid.Row="0"
                       Text="{local:Loc AiRoiEditorTitle}"
                       FontSize="18"
                       FontWeight="SemiBold"
                       HorizontalAlignment="Center" />
            <TextBlock Grid.Row="1"
                       x:Name="SubheaderText"
                       Foreground="#8B95A7"
                       FontSize="13"
                       HorizontalAlignment="Center"
                       Margin="0,4,0,16" />

            <!-- Editor body: snapshot + canvas overlay + right-side controls -->
            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="220" />
                </Grid.ColumnDefinitions>

                <!-- Image + click-canvas inside a Viewbox so the source-pixel
                     coordinate space scales uniformly to the available area.
                     Mouse positions reported relative to DrawCanvas come back in
                     source-pixel coordinates regardless of zoom level - the Viewbox
                     transform is accounted for by WPF's hit-test pipeline. -->
                <Border Grid.Column="0"
                        Background="#0F1115"
                        BorderBrush="#2A2F3A"
                        BorderThickness="1"
                        CornerRadius="6"
                        ClipToBounds="True">
                    <Grid>
                        <!-- "No frame" placeholder; hidden when snapshot present. -->
                        <TextBlock x:Name="NoFramePlaceholder"
                                   Text="{local:Loc AiRoiNoFrame}"
                                   Foreground="#8B95A7"
                                   FontSize="13"
                                   TextWrapping="Wrap"
                                   TextAlignment="Center"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Margin="32" />
                        <Viewbox x:Name="EditorViewbox" Stretch="Uniform" Visibility="Collapsed">
                            <Grid x:Name="EditorContent">
                                <Image x:Name="SnapshotImage" Stretch="Fill" />
                                <Canvas x:Name="DrawCanvas"
                                        Background="Transparent"
                                        MouseLeftButtonDown="OnCanvasClick"
                                        MouseMove="OnCanvasMouseMove"
                                        MouseLeftButtonUp="OnCanvasMouseUp">
                                    <!-- Filled polygon. Stroke and Fill stay subtle so the
                                         underlying camera content is still readable while
                                         editing. -->
                                    <Polygon x:Name="PolygonShape"
                                             Stroke="#4DABF7"
                                             StrokeThickness="3"
                                             Fill="#404DABF7" />
                                </Canvas>
                            </Grid>
                        </Viewbox>
                    </Grid>
                </Border>

                <!-- Right column: instructions, point count, action buttons -->
                <StackPanel Grid.Column="1" Margin="20,0,0,0">
                    <TextBlock Text="{local:Loc AiRoiEditorHint}"
                               Foreground="#8B95A7"
                               FontSize="12"
                               TextWrapping="Wrap"
                               Margin="0,0,0,16" />

                    <TextBlock x:Name="PointCountText"
                               Foreground="#E6E6E6"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Margin="0,0,0,12" />

                    <Button Content="{local:Loc AiRoiUndo}"
                            Click="OnUndoPoint"
                            Background="Transparent"
                            Foreground="#E6E6E6"
                            BorderBrush="#374050"
                            BorderThickness="1"
                            Padding="10,6"
                            Cursor="Hand"
                            Margin="0,0,0,8" />
                    <Button Content="{local:Loc AiRoiClear}"
                            Click="OnClearPoints"
                            Background="Transparent"
                            Foreground="#FF7777"
                            BorderBrush="#FF7777"
                            BorderThickness="1"
                            Padding="10,6"
                            Cursor="Hand" />
                </StackPanel>
            </Grid>

            <!-- Footer -->
            <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0">
                <Button Content="{local:Loc SetupCancel}"
                        Click="OnCancel"
                        Background="Transparent" Foreground="#8B95A7"
                        BorderBrush="#374050" BorderThickness="1"
                        Padding="14,8" Cursor="Hand"
                        Margin="0,0,8,0" />
                <Button Content="{local:Loc SetupSave}"
                        Click="OnOk"
                        IsDefault="True"
                        Background="#4DABF7" Foreground="#0F1115"
                        FontWeight="SemiBold"
                        BorderThickness="0"
                        Padding="14,8" Cursor="Hand" />
            </StackPanel>
        </Grid>
    </Border>
</Window>
