<Window x:Class="InteractiveMask.Display.HelpWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:InteractiveMask.Display"
        Title="InteractiveMask - Handleiding"
        Width="1100" Height="780"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        UseLayoutRounding="True"
        TextOptions.TextFormattingMode="Ideal"
        TextOptions.TextRenderingMode="ClearType"
        FontFamily="Segoe UI Variable Display, Segoe UI"
        Foreground="#E6E6E6">

    <Window.Resources>
        <!-- ====== Color tokens (mirror SetupWindow) ====== -->
        <SolidColorBrush x:Key="bg.canvas"      Color="#14171C" />
        <SolidColorBrush x:Key="bg.sidebar"     Color="#1A1D24" />
        <SolidColorBrush x:Key="bg.card"        Color="#1D2129" />
        <SolidColorBrush x:Key="bg.input"       Color="#232831" />
        <SolidColorBrush x:Key="bg.subtle"      Color="#1B1F26" />
        <SolidColorBrush x:Key="border"         Color="#2A2F3A" />
        <SolidColorBrush x:Key="border.strong"  Color="#374050" />
        <SolidColorBrush x:Key="text"           Color="#E6E6E6" />
        <SolidColorBrush x:Key="text.muted"     Color="#8B95A7" />
        <SolidColorBrush x:Key="text.dim"       Color="#5A6273" />
        <SolidColorBrush x:Key="accent"         Color="#4DABF7" />
        <SolidColorBrush x:Key="accent.soft"    Color="#1F3A52" />
        <SolidColorBrush x:Key="green"          Color="#41D27A" />
        <SolidColorBrush x:Key="amber"          Color="#FFB347" />
        <SolidColorBrush x:Key="danger"         Color="#FF7777" />

        <!-- ====== Sidebar nav button ====== -->
        <Style x:Key="NavItem" TargetType="RadioButton">
            <Setter Property="Foreground" Value="{StaticResource text.muted}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Padding"    Value="12,10" />
            <Setter Property="Margin"     Value="8,2" />
            <Setter Property="Cursor"     Value="Hand" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="root"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="root" Property="Background" Value="#22262F" />
                                <Setter Property="Foreground" Value="{StaticResource text}" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="root" Property="Background" Value="{StaticResource accent.soft}" />
                                <Setter Property="Foreground" Value="{StaticResource accent}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ====== Buttons ====== -->
        <Style x:Key="BtnPrimary" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource accent}" />
            <Setter Property="Foreground" Value="#0F1115" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding"    Value="18,9" />
            <Setter Property="Cursor"     Value="Hand" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b" Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="#74C0FC" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="b" Property="Background" Value="#3B96D8" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="BtnGhost" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{StaticResource text.muted}" />
            <Setter Property="Padding"    Value="18,9" />
            <Setter Property="Cursor"     Value="Hand" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="{StaticResource border.strong}" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="#22262F" />
                                <Setter Property="Foreground" Value="{StaticResource text}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ChromeBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{StaticResource text.muted}" />
            <Setter Property="Width" Value="40" />
            <Setter Property="Height" Value="32" />
            <Setter Property="FontFamily" Value="Segoe Fluent Icons,Segoe MDL2 Assets" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="#22262F" />
                                <Setter Property="Foreground" Value="{StaticResource text}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ChromeBtnClose" TargetType="Button" BasedOn="{StaticResource ChromeBtn}">
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#C42B1C" />
                    <Setter Property="Foreground" Value="White" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ====== Section / labels ====== -->
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource text}" />
            <Setter Property="FontSize"   Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin"     Value="0,0,0,8" />
        </Style>
        <Style x:Key="BodyText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource text}" />
            <Setter Property="FontSize"   Value="13" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="Margin"     Value="0,0,0,10" />
            <Setter Property="LineHeight" Value="20" />
        </Style>
        <Style x:Key="MutedText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource text.muted}" />
            <Setter Property="FontSize"   Value="12" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>
        <Style x:Key="PageTitle" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="26" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource text}" />
        </Style>
        <Style x:Key="PageSubtitle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource text.muted}" />
            <Setter Property="Margin" Value="0,4,0,24" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource bg.card}" />
            <Setter Property="BorderBrush" Value="{StaticResource border}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="22" />
            <Setter Property="Margin" Value="0,0,0,16" />
        </Style>

        <!-- ====== Custom dark scrollbars (same as SetupWindow) ====== -->
        <Style x:Key="ScrollThumb" TargetType="Thumb">
            <Setter Property="Background" Value="#3A4051" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border x:Name="b" CornerRadius="4"
                                Background="{TemplateBinding Background}" Margin="3,2" />
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="#4F5667" />
                            </Trigger>
                            <Trigger Property="IsDragging" Value="True">
                                <Setter TargetName="b" Property="Background" Value="#5C6478" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ScrollPageButton" TargetType="RepeatButton">
            <Setter Property="IsTabStop" Value="False" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RepeatButton">
                        <Border Background="Transparent" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ScrollBar">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Style.Triggers>
                <Trigger Property="Orientation" Value="Vertical">
                    <Setter Property="Width" Value="10" />
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ScrollBar">
                                <Grid>
                                    <Border Background="Transparent" />
                                    <Track x:Name="PART_Track" IsDirectionReversed="True">
                                        <Track.DecreaseRepeatButton>
                                            <RepeatButton Style="{StaticResource ScrollPageButton}" Command="ScrollBar.PageUpCommand" />
                                        </Track.DecreaseRepeatButton>
                                        <Track.Thumb>
                                            <Thumb Style="{StaticResource ScrollThumb}" />
                                        </Track.Thumb>
                                        <Track.IncreaseRepeatButton>
                                            <RepeatButton Style="{StaticResource ScrollPageButton}" Command="ScrollBar.PageDownCommand" />
                                        </Track.IncreaseRepeatButton>
                                    </Track>
                                </Grid>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ====== FAQ block ====== -->
        <Style x:Key="FaqQuestion" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource text}" />
            <Setter Property="FontSize"   Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="Margin" Value="0,0,0,4" />
        </Style>
        <Style x:Key="FaqAnswer" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource text.muted}" />
            <Setter Property="FontSize"   Value="12" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="Margin" Value="0,0,0,14" />
            <Setter Property="LineHeight" Value="18" />
        </Style>
    </Window.Resources>

    <!-- =============== Outer rounded container with subtle shadow =============== -->
    <Border Background="{StaticResource bg.canvas}"
            BorderBrush="{StaticResource border}"
            BorderThickness="1"
            CornerRadius="18"
            Margin="14"
            ClipToBounds="True">
        <Border.Effect>
            <DropShadowEffect Color="Black" BlurRadius="22" ShadowDepth="0" Opacity="0.6" />
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- =============== Title bar =============== -->
            <Grid Grid.Row="0" x:Name="TitleBar" Height="36"
                  Background="Transparent"
                  MouseLeftButtonDown="OnTitleBarMouseDown">
                <TextBlock x:Name="TitleBarText"
                           Foreground="{StaticResource text.muted}"
                           FontSize="12"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Left"
                           Margin="20,0,0,0" />
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="&#xE8BB;" Style="{StaticResource ChromeBtnClose}" Click="OnClose" />
                </StackPanel>
            </Grid>

            <!-- =============== Body =============== -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="240" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- ============== Sidebar ============== -->
                <Border Grid.Column="0" Background="{StaticResource bg.sidebar}">
                    <DockPanel>
                        <Border DockPanel.Dock="Top" Padding="20,8,20,18">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <Border Width="28" Height="28" CornerRadius="6"
                                            Background="{StaticResource accent}" Margin="0,0,10,0">
                                        <TextBlock Text="&#xE897;"
                                                   FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                                                   FontSize="16" Foreground="#0F1115"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                    <TextBlock Text="InteractiveMask" FontSize="14" FontWeight="SemiBold"
                                               Foreground="{StaticResource text}" VerticalAlignment="Center" />
                                </StackPanel>
                                <TextBlock x:Name="SidebarTitle" Margin="0,12,0,0"
                                           FontSize="22" FontWeight="SemiBold" />
                                <TextBlock x:Name="SidebarSubtitle"
                                           Foreground="{StaticResource text.muted}" FontSize="12" Margin="0,2,0,0"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>

                        <Border DockPanel.Dock="Top" BorderBrush="{StaticResource border}"
                                BorderThickness="0,1,0,0" Margin="14,0" />

                        <StackPanel Margin="0,12,0,0">
                            <RadioButton x:Name="NavWelcome"   Style="{StaticResource NavItem}" IsChecked="True"
                                         Tag="WelcomePanel"   Checked="OnNavChecked">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE80F;" FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets" FontSize="16" Margin="0,0,12,0" />
                                    <TextBlock x:Name="NavWelcomeText"   FontSize="13" />
                                </StackPanel>
                            </RadioButton>
                            <RadioButton x:Name="NavScreen"    Style="{StaticResource NavItem}"
                                         Tag="ScreenPanel"    Checked="OnNavChecked">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xF246;" FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets" FontSize="16" Margin="0,0,12,0" />
                                    <TextBlock x:Name="NavScreenText"    FontSize="13" />
                                </StackPanel>
                            </RadioButton>
                            <RadioButton x:Name="NavPrivacyOn"  Style="{StaticResource NavItem}"
                                         Tag="PrivacyOnPanel"  Checked="OnNavChecked">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE72E;" FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets" FontSize="16" Margin="0,0,12,0" />
                                    <TextBlock x:Name="NavPrivacyOnText"  FontSize="13" />
                                </StackPanel>
                            </RadioButton>
                            <RadioButton x:Name="NavPrivacyOff" Style="{StaticResource NavItem}"
                                         Tag="PrivacyOffPanel" Checked="OnNavChecked">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE785;" FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets" FontSize="16" Margin="0,0,12,0" />
                                    <TextBlock x:Name="NavPrivacyOffText" FontSize="13" />
                                </StackPanel>
                            </RadioButton>
                            <RadioButton x:Name="NavAutoOff"   Style="{StaticResource NavItem}"
                                         Tag="AutoOffPanel"   Checked="OnNavChecked">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE823;" FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets" FontSize="16" Margin="0,0,12,0" />
                                    <TextBlock x:Name="NavAutoOffText"   FontSize="13" />
                                </StackPanel>
                            </RadioButton>
                            <RadioButton x:Name="NavRemote"    Style="{StaticResource NavItem}"
                                         Tag="RemotePanel"    Checked="OnNavChecked">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE968;" FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets" FontSize="16" Margin="0,0,12,0" />
                                    <TextBlock x:Name="NavRemoteText"    FontSize="13" />
                                </StackPanel>
                            </RadioButton>
                            <RadioButton x:Name="NavAdmin"     Style="{StaticResource NavItem}"
                                         Tag="AdminPanel"     Checked="OnNavChecked">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE77B;" FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets" FontSize="16" Margin="0,0,12,0" />
                                    <TextBlock x:Name="NavAdminText"     FontSize="13" />
                                </StackPanel>
                            </RadioButton>
                            <RadioButton x:Name="NavFaq"       Style="{StaticResource NavItem}"
                                         Tag="FaqPanel"       Checked="OnNavChecked">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE9CE;" FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets" FontSize="16" Margin="0,0,12,0" />
                                    <TextBlock x:Name="NavFaqText"       FontSize="13" />
                                </StackPanel>
                            </RadioButton>
                        </StackPanel>
                    </DockPanel>
                </Border>

                <!-- ============== Content area ============== -->
                <Grid Grid.Column="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" Padding="36,28,36,12">
                        <Grid>

                            <!-- ============================ 1. Welcome ============================ -->
                            <StackPanel x:Name="WelcomePanel">
                                <TextBlock x:Name="WelcomeTitleText"    Style="{StaticResource PageTitle}" />
                                <TextBlock x:Name="WelcomeSubtitleText" Style="{StaticResource PageSubtitle}" />

                                <Border Style="{StaticResource Card}">
                                    <StackPanel>
                                        <TextBlock x:Name="WelcomeIntroText" Style="{StaticResource BodyText}" />

                                        <!-- Inline graphic: a stylised "shield + camera" mark -->
                                        <Border HorizontalAlignment="Left" Margin="0,8,0,8"
                                                Width="180" Height="120"
                                                Background="{StaticResource bg.subtle}"
                                                BorderBrush="{StaticResource border}"
                                                BorderThickness="1" CornerRadius="8">
                                            <Grid>
                                                <Ellipse Width="64" Height="64"
                                                         Fill="{StaticResource accent.soft}"
                                                         HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                <TextBlock Text="&#xE72E;"
                                                           FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                                                           FontSize="32"
                                                           Foreground="{StaticResource accent}"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            </Grid>
                                        </Border>
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource Card}">
                                    <StackPanel>
                                        <TextBlock x:Name="WelcomeWhoForTitleText" Style="{StaticResource SectionHeader}" />
                                        <TextBlock x:Name="WelcomeWhoForBodyText"  Style="{StaticResource BodyText}" />
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource Card}">
                                    <StackPanel>
                                        <TextBlock x:Name="WelcomeWhatIsMaskTitleText" Style="{StaticResource SectionHeader}" />
                                        <TextBlock x:Name="WelcomeWhatIsMaskBodyText"  Style="{StaticResource BodyText}" />
                                    </StackPanel>
                                </Border>
                            </StackPanel>

                            <!-- ============================ 2. Screen ============================ -->
                            <StackPanel x:Name="ScreenPanel" Visibility="Collapsed">
                                <TextBlock x:Name="ScreenTitleText"    Style="{StaticResource PageTitle}" />
                                <TextBlock x:Name="ScreenSubtitleText" Style="{StaticResource PageSubtitle}" />

                                <Border Style="{StaticResource Card}">
                                    <StackPanel>
                                        <TextBlock x:Name="ScreenIntroText" Style="{StaticResource BodyText}" />

                                        <!-- Status legend -->
                                        <TextBlock x:Name="ScreenStatusTitleText" Style="{StaticResource SectionHeader}" Margin="0,8,0,8" />
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                                <Ellipse Width="10" Height="10" Fill="{StaticResource green}"
                                                         VerticalAlignment="Center" Margin="0,0,10,0" />
                                                <TextBlock x:Name="ScreenStatusGreenText" Foreground="{StaticResource text}" FontSize="13" />
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                                <Ellipse Width="10" Height="10" Fill="{StaticResource amber}"
                                                         VerticalAlignment="Center" Margin="0,0,10,0" />
                                                <TextBlock x:Name="ScreenStatusAmberText" Foreground="{StaticResource text}" FontSize="13" />
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                                <Ellipse Width="10" Height="10" Fill="{StaticResource danger}"
                                                         VerticalAlignment="Center" Margin="0,0,10,0" />
                                                <TextBlock x:Name="ScreenStatusRedText"   Foreground="{StaticResource text}" FontSize="13" />
                                            </StackPanel>
                                        </StackPanel>
                                        <TextBlock x:Name="ScreenEmptyTileText" Style="{StaticResource MutedText}" Margin="0,0,0,16" />
                                    </StackPanel>
                                </Border>

                                <!-- Mini 2x2 grid graphic showing 4 tile states -->
                                <Border Style="{StaticResource Card}">
                                    <StackPanel>
                                        <TextBlock x:Name="ScreenLegendCaptionText" Style="{StaticResource MutedText}" Margin="0,0,0,12" />
                                        <Border Background="#0F1115" BorderBrush="{StaticResource border}"
                                                BorderThickness="1" CornerRadius="6"
                                                Padding="10" HorizontalAlignment="Left">
                                            <UniformGrid Rows="2" Columns="2" Width="380" Height="220">
                                                <!-- Tile: Live -->
                                                <Border Background="#0B1A12" BorderBrush="{StaticResource border}"
                                                        BorderThickness="1" CornerRadius="4" Margin="4">
                                                    <Grid>
                                                        <TextBlock Text="&#xE8B5;"
                                                                   FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                                                                   FontSize="36"
                                                                   Foreground="#2F8C5C"
                                                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                        <StackPanel Orientation="Horizontal"
                                                                    HorizontalAlignment="Left" VerticalAlignment="Bottom"
                                                                    Margin="8">
                                                            <Ellipse Width="8" Height="8" Fill="{StaticResource green}"
                                                                     VerticalAlignment="Center" Margin="0,0,6,0" />
                                                            <TextBlock x:Name="LegendTileLiveText"
                                                                       Foreground="{StaticResource text}"
                                                                       FontSize="11" />
                                                        </StackPanel>
                                                    </Grid>
                                                </Border>
                                                <!-- Tile: Connecting -->
                                                <Border Background="#1B1612" BorderBrush="{StaticResource border}"
                                                        BorderThickness="1" CornerRadius="4" Margin="4">
                                                    <Grid>
                                                        <TextBlock Text="&#xE895;"
                                                                   FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                                                                   FontSize="32"
                                                                   Foreground="#8B6E3C"
                                                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                        <StackPanel Orientation="Horizontal"
                                                                    HorizontalAlignment="Left" VerticalAlignment="Bottom"
                                                                    Margin="8">
                                                            <Ellipse Width="8" Height="8" Fill="{StaticResource amber}"
                                                                     VerticalAlignment="Center" Margin="0,0,6,0" />
                                                            <TextBlock x:Name="LegendTileConnectingText"
                                                                       Foreground="{StaticResource text}"
                                                                       FontSize="11" />
                                                        </StackPanel>
                                                    </Grid>
                                                </Border>
                                                <!-- Tile: Lost -->
                                                <Border Background="#1F1014" BorderBrush="{StaticResource border}"
                                                        BorderThickness="1" CornerRadius="4" Margin="4">
                                                    <Grid>
                                                        <TextBlock Text="&#xF384;"
                                                                   FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                                                                   FontSize="32"
                                                                   Foreground="#8C3A3A"
                                                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                        <StackPanel Orientation="Horizontal"
                                                                    HorizontalAlignment="Left" VerticalAlignment="Bottom"
                                                                    Margin="8">
                                                            <Ellipse Width="8" Height="8" Fill="{StaticResource danger}"
                                                                     VerticalAlignment="Center" Margin="0,0,6,0" />
                                                            <TextBlock x:Name="LegendTileLostText"
                                                                       Foreground="{StaticResource text}"
                                                                       FontSize="11" />
                                                        </StackPanel>
                                                    </Grid>
                                                </Border>
                                                <!-- Tile: Masked -->
                                                <Border Background="#0F1115" BorderBrush="{StaticResource border}"
                                                        BorderThickness="1" CornerRadius="4" Margin="4">
                                                    <Grid>
                                                        <Rectangle Fill="#000000" Opacity="0.55" />
                                                        <TextBlock Text="&#xE890;"
                                                                   FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                                                                   FontSize="32"
                                                                   Foreground="{StaticResource text.muted}"
                                                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                        <TextBlock x:Name="LegendTileMaskedText"
                                                                   Foreground="{StaticResource text}"
                                                                   FontSize="11"
                                                                   FontWeight="SemiBold"
                                                                   HorizontalAlignment="Left" VerticalAlignment="Bottom"
                                                                   Margin="8" />
                                                    </Grid>
                                                </Border>
                                            </UniformGrid>
                                        </Border>
                                    </StackPanel>
                                </Border>
                            </StackPanel>

                            <!-- ============================ 3. Privacy on ============================ -->
                            <StackPanel x:Name="PrivacyOnPanel" Visibility="Collapsed">
                                <TextBlock x:Name="PrivacyOnTitleText"    Style="{StaticResource PageTitle}" />
                                <TextBlock x:Name="PrivacyOnSubtitleText" Style="{StaticResource PageSubtitle}" />

                                <Border Style="{StaticResource Card}">
                                    <StackPanel>
                                        <TextBlock x:Name="PrivacyOnIntroText" Style="{StaticResource BodyText}" />
                                        <TextBlock x:Name="PrivacyOnStepsText" Style="{StaticResource BodyText}" />

                                        <!-- Inline graphic: cursor -> tile -> mask overlay -->
                                        <StackPanel Orientation="Horizontal" Margin="0,8,0,8">
                                            <Border Width="80" Height="80"
                                                    Background="{StaticResource bg.subtle}"
                                                    BorderBrush="{StaticResource border}"
                                                    BorderThickness="1" CornerRadius="6">
                                                <TextBlock Text="&#xE7C9;"
                                                           FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                                                           FontSize="32"
                                                           Foreground="{StaticResource accent}"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            </Border>
                                            <TextBlock Text="&#xE76C;"
                                                       FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                                                       FontSize="20"
                                                       Foreground="{StaticResource text.muted}"
                                                       VerticalAlignment="Center" Margin="14,0" />
                                            <Border Width="80" Height="80"
                                                    Background="#0B1A12"
                                                    BorderBrush="{StaticResource border}"
                                                    BorderThickness="1" CornerRadius="6">
                                                <TextBlock Text="&#xE8B5;"
                                                           FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                                                           FontSize="28"
                                                           Foreground="#2F8C5C"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            </Border>
                                            <TextBlock Text="&#xE76C;"
                                                       FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                                                       FontSize="20"
                                                       Foreground="{StaticResource text.muted}"
                                                       VerticalAlignment="Center" Margin="14,0" />
                                            <Border Width="80" Height="80"
                                                    Background="#0F1115"
                                                    BorderBrush="{StaticResource border}"
                                                    BorderThickness="1" CornerRadius="6">
                                                <Grid>
                                                    <Rectangle Fill="#000000" Opacity="0.55" />
                                                    <TextBlock Text="&#xE72E;"
                                                               FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                                                               FontSize="26"
                                                               Foreground="{StaticResource accent}"
                                                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                </Grid>
                                            </Border>
                                        </StackPanel>

                                        <Border Background="#1A2331" BorderBrush="#22324A" BorderThickness="1"
                                                CornerRadius="6" Padding="12,10" Margin="0,8,0,0">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="&#xE946;"
                                                           FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                                                           Foreground="{StaticResource accent}"
                                                           Margin="0,0,8,0" VerticalAlignment="Top" />
                                                <TextBlock x:Name="PrivacyOnFirstPinText" Style="{StaticResource MutedText}" />
                                            </StackPanel>
                                        </Border>

                                        <TextBlock x:Name="PrivacyOnTipText" Style="{StaticResource MutedText}" Margin="0,12,0,0" />
                                    </StackPanel>
                                </Border>
                            </StackPanel>

                            <!-- ============================ 4. Privacy off ============================ -->
                            <StackPanel x:Name="PrivacyOffPanel" Visibility="Collapsed">
                                <TextBlock x:Name="PrivacyOffTitleText"    Style="{StaticResource PageTitle}" />
                                <TextBlock x:Name="PrivacyOffSubtitleText" Style="{StaticResource PageSubtitle}" />

                                <Border Style="{StaticResource Card}">
                                    <StackPanel>
                                        <TextBlock x:Name="PrivacyOffIntroText" Style="{StaticResource BodyText}" />

                                        <StackPanel Orientation="Horizontal" Margin="0,4,0,8">
                                            <TextBlock Text="&#xE785;"
                                                       FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                                                       FontSize="16"
                                                       Foreground="{StaticResource accent}"
                                                       Margin="0,2,10,0" VerticalAlignment="Top" />
                                            <TextBlock x:Name="PrivacyOffPinFlowText" Style="{StaticResource BodyText}" />
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                            <TextBlock Text="&#xE77B;"
                                                       FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                                                       FontSize="16"
                                                       Foreground="{StaticResource accent}"
                                                       Margin="0,2,10,0" VerticalAlignment="Top" />
                                            <TextBlock x:Name="PrivacyOffAdFlowText" Style="{StaticResource BodyText}" />
                                        </StackPanel>
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource Card}">
                                    <StackPanel>
                                        <TextBlock x:Name="PrivacyOffLockoutTitleText" Style="{StaticResource SectionHeader}" />
                                        <TextBlock x:Name="PrivacyOffLockoutBodyText"  Style="{StaticResource BodyText}" />
                                    </StackPanel>
                                </Border>
                            </StackPanel>

                            <!-- ============================ 5. Auto-off ============================ -->
                            <StackPanel x:Name="AutoOffPanel" Visibility="Collapsed">
                                <TextBlock x:Name="AutoOffTitleText"    Style="{StaticResource PageTitle}" />
                                <TextBlock x:Name="AutoOffSubtitleText" Style="{StaticResource PageSubtitle}" />

                                <Border Style="{StaticResource Card}">
                                    <StackPanel>
                                        <TextBlock x:Name="AutoOffIntroText"        Style="{StaticResource BodyText}" />
                                        <TextBlock x:Name="AutoOffWarningRingText"  Style="{StaticResource BodyText}" />

                                        <!-- Inline graphic: timeline with start, warning, done -->
                                        <Grid Margin="0,12,0,8" Height="80">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>

                                            <!-- Bar -->
                                            <Border Grid.ColumnSpan="3" Height="6" CornerRadius="3"
                                                    Background="{StaticResource bg.input}"
                                                    VerticalAlignment="Top" Margin="20,28,20,0" />
                                            <Border Grid.ColumnSpan="2" Height="6" CornerRadius="3"
                                                    Background="{StaticResource accent.soft}"
                                                    VerticalAlignment="Top" HorizontalAlignment="Stretch"
                                                    Margin="20,28,0,0" />

                                            <!-- Markers -->
                                            <Grid Grid.Column="0" HorizontalAlignment="Left" Margin="14,16,0,0">
                                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Top">
                                                    <Ellipse Width="14" Height="14"
                                                             Fill="{StaticResource accent}" HorizontalAlignment="Center" Margin="0,0,0,8" />
                                                    <TextBlock x:Name="AutoOffPhaseStartText"
                                                               Foreground="{StaticResource text}" FontSize="11"
                                                               HorizontalAlignment="Center" />
                                                </StackPanel>
                                            </Grid>
                                            <Grid Grid.Column="1" HorizontalAlignment="Center" Margin="0,16,0,0">
                                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Top">
                                                    <Ellipse Width="14" Height="14"
                                                             Fill="{StaticResource amber}" HorizontalAlignment="Center" Margin="0,0,0,8" />
                                                    <TextBlock x:Name="AutoOffPhaseWarningText"
                                                               Foreground="{StaticResource text}" FontSize="11"
                                                               HorizontalAlignment="Center" />
                                                </StackPanel>
                                            </Grid>
                                            <Grid Grid.Column="2" HorizontalAlignment="Right" Margin="0,16,14,0">
                                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Top">
                                                    <Ellipse Width="14" Height="14"
                                                             Fill="{StaticResource green}" HorizontalAlignment="Center" Margin="0,0,0,8" />
                                                    <TextBlock x:Name="AutoOffPhaseDoneText"
                                                               Foreground="{StaticResource text}" FontSize="11"
                                                               HorizontalAlignment="Center" />
                                                </StackPanel>
                                            </Grid>
                                        </Grid>

                                        <TextBlock x:Name="AutoOffNoteText" Style="{StaticResource MutedText}" Margin="0,16,0,0" />
                                    </StackPanel>
                                </Border>
                            </StackPanel>

                            <!-- ============================ 6. Remote ============================ -->
                            <StackPanel x:Name="RemotePanel" Visibility="Collapsed">
                                <TextBlock x:Name="RemoteTitleText"    Style="{StaticResource PageTitle}" />
                                <TextBlock x:Name="RemoteSubtitleText" Style="{StaticResource PageSubtitle}" />

                                <Border Style="{StaticResource Card}">
                                    <StackPanel>
                                        <TextBlock x:Name="RemoteIntroText" Style="{StaticResource BodyText}" />

                                        <!-- Stylised browser bar -->
                                        <Border Background="{StaticResource bg.subtle}"
                                                BorderBrush="{StaticResource border}"
                                                BorderThickness="1" CornerRadius="6"
                                                Padding="10,8" Margin="0,4,0,8" HorizontalAlignment="Left">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="&#xE968;"
                                                           FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                                                           FontSize="14"
                                                           Foreground="{StaticResource text.muted}"
                                                           VerticalAlignment="Center" Margin="0,0,8,0" />
                                                <TextBlock x:Name="RemoteUrlNoteText"
                                                           Foreground="{StaticResource text}" FontSize="12"
                                                           VerticalAlignment="Center" />
                                            </StackPanel>
                                        </Border>

                                        <TextBlock x:Name="RemoteSamePinText" Style="{StaticResource BodyText}" />
                                        <TextBlock x:Name="RemoteSharedText"  Style="{StaticResource MutedText}" />
                                    </StackPanel>
                                </Border>
                            </StackPanel>

                            <!-- ============================ 7. Admin ============================ -->
                            <StackPanel x:Name="AdminPanel" Visibility="Collapsed">
                                <TextBlock x:Name="AdminTitleText"    Style="{StaticResource PageTitle}" />
                                <TextBlock x:Name="AdminSubtitleText" Style="{StaticResource PageSubtitle}" />

                                <Border Style="{StaticResource Card}">
                                    <StackPanel>
                                        <TextBlock x:Name="AdminOpeningText" Style="{StaticResource BodyText}" />
                                        <TextBlock x:Name="AdminTabsText"    Style="{StaticResource BodyText}" />
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource Card}">
                                    <StackPanel>
                                        <TextBlock x:Name="AdminKioskText" Style="{StaticResource BodyText}" />
                                        <TextBlock x:Name="AdminAdText"    Style="{StaticResource BodyText}" />
                                        <TextBlock x:Name="AdminAuditText" Style="{StaticResource BodyText}" />
                                    </StackPanel>
                                </Border>

                                <Border Background="#1A2331" BorderBrush="#22324A" BorderThickness="1"
                                        CornerRadius="6" Padding="12,10">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE946;"
                                                   FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                                                   Foreground="{StaticResource accent}"
                                                   Margin="0,0,8,0" VerticalAlignment="Top" />
                                        <TextBlock x:Name="AdminTechNoteText" Style="{StaticResource MutedText}" />
                                    </StackPanel>
                                </Border>
                            </StackPanel>

                            <!-- ============================ 8. FAQ ============================ -->
                            <StackPanel x:Name="FaqPanel" Visibility="Collapsed">
                                <TextBlock x:Name="FaqTitleText"    Style="{StaticResource PageTitle}" />
                                <TextBlock x:Name="FaqSubtitleText" Style="{StaticResource PageSubtitle}" />

                                <Border Style="{StaticResource Card}">
                                    <StackPanel>
                                        <Grid Margin="0,0,0,10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="22" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="&#xE76C;" FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                                                       Foreground="{StaticResource accent}" FontSize="13" Margin="0,2,0,0" />
                                            <StackPanel Grid.Column="1">
                                                <TextBlock x:Name="FaqQ1Text" Style="{StaticResource FaqQuestion}" />
                                                <TextBlock x:Name="FaqA1Text" Style="{StaticResource FaqAnswer}" />
                                            </StackPanel>
                                        </Grid>
                                        <Grid Margin="0,0,0,10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="22" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="&#xE76C;" FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                                                       Foreground="{StaticResource accent}" FontSize="13" Margin="0,2,0,0" />
                                            <StackPanel Grid.Column="1">
                                                <TextBlock x:Name="FaqQ2Text" Style="{StaticResource FaqQuestion}" />
                                                <TextBlock x:Name="FaqA2Text" Style="{StaticResource FaqAnswer}" />
                                            </StackPanel>
                                        </Grid>
                                        <Grid Margin="0,0,0,10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="22" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="&#xE76C;" FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                                                       Foreground="{StaticResource accent}" FontSize="13" Margin="0,2,0,0" />
                                            <StackPanel Grid.Column="1">
                                                <TextBlock x:Name="FaqQ3Text" Style="{StaticResource FaqQuestion}" />
                                                <TextBlock x:Name="FaqA3Text" Style="{StaticResource FaqAnswer}" />
                                            </StackPanel>
                                        </Grid>
                                        <Grid Margin="0,0,0,10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="22" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="&#xE76C;" FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                                                       Foreground="{StaticResource accent}" FontSize="13" Margin="0,2,0,0" />
                                            <StackPanel Grid.Column="1">
                                                <TextBlock x:Name="FaqQ4Text" Style="{StaticResource FaqQuestion}" />
                                                <TextBlock x:Name="FaqA4Text" Style="{StaticResource FaqAnswer}" />
                                            </StackPanel>
                                        </Grid>
                                        <Grid Margin="0,0,0,10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="22" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="&#xE76C;" FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                                                       Foreground="{StaticResource accent}" FontSize="13" Margin="0,2,0,0" />
                                            <StackPanel Grid.Column="1">
                                                <TextBlock x:Name="FaqQ5Text" Style="{StaticResource FaqQuestion}" />
                                                <TextBlock x:Name="FaqA5Text" Style="{StaticResource FaqAnswer}" />
                                            </StackPanel>
                                        </Grid>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="22" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="&#xE76C;" FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                                                       Foreground="{StaticResource accent}" FontSize="13" Margin="0,2,0,0" />
                                            <StackPanel Grid.Column="1">
                                                <TextBlock x:Name="FaqQ6Text" Style="{StaticResource FaqQuestion}" />
                                                <TextBlock x:Name="FaqA6Text" Style="{StaticResource FaqAnswer}" />
                                            </StackPanel>
                                        </Grid>
                                    </StackPanel>
                                </Border>
                            </StackPanel>

                        </Grid>
                    </ScrollViewer>

                    <!-- ============== Action bar ============== -->
                    <Border Grid.Row="1" BorderBrush="{StaticResource border}" BorderThickness="0,1,0,0" Padding="36,16">
                        <Grid>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button x:Name="CloseButton" Style="{StaticResource BtnPrimary}" Click="OnClose" />
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>
