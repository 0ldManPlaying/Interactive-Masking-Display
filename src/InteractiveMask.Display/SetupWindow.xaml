<Window x:Class="InteractiveMask.Display.SetupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:InteractiveMask.Display"
        Title="InteractiveMask - Setup"
        Icon="pack://application:,,,/app.ico"
        Width="1280" Height="1000"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        UseLayoutRounding="True"
        TextOptions.TextFormattingMode="Ideal"
        TextOptions.TextRenderingMode="ClearType"
        FontFamily="Segoe UI Variable Display, Segoe UI"
        Foreground="#E6E6E6">

    <Window.Resources>
        <!-- ====== Color tokens (Mockup A) ====== -->
        <SolidColorBrush x:Key="bg.canvas"      Color="#14171C" />
        <SolidColorBrush x:Key="bg.sidebar"     Color="#1A1D24" />
        <SolidColorBrush x:Key="bg.card"        Color="#1D2129" />
        <SolidColorBrush x:Key="bg.input"       Color="#232831" />
        <SolidColorBrush x:Key="bg.input.focus" Color="#2A3140" />
        <SolidColorBrush x:Key="bg.subtle"      Color="#1B1F26" />
        <SolidColorBrush x:Key="border"         Color="#2A2F3A" />
        <SolidColorBrush x:Key="border.strong"  Color="#374050" />
        <SolidColorBrush x:Key="text"           Color="#E6E6E6" />
        <SolidColorBrush x:Key="text.muted"     Color="#8B95A7" />
        <SolidColorBrush x:Key="text.dim"       Color="#5A6273" />
        <SolidColorBrush x:Key="accent"         Color="#4DABF7" />
        <SolidColorBrush x:Key="accent.soft"    Color="#1F3A52" />
        <SolidColorBrush x:Key="green"          Color="#41D27A" />
        <SolidColorBrush x:Key="amber"          Color="#FFB347" />
        <SolidColorBrush x:Key="danger"         Color="#FF7777" />

        <!-- ====== Sidebar nav button ====== -->
        <Style x:Key="NavItem" TargetType="RadioButton">
            <Setter Property="Foreground" Value="{StaticResource text.muted}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Padding"    Value="12,10" />
            <Setter Property="Margin"     Value="8,2" />
            <Setter Property="Cursor"     Value="Hand" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="root"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="root" Property="Background" Value="#22262F" />
                                <Setter Property="Foreground" Value="{StaticResource text}" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="root" Property="Background" Value="{StaticResource accent.soft}" />
                                <Setter Property="Foreground" Value="{StaticResource accent}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ====== Buttons ====== -->
        <Style x:Key="BtnPrimary" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource accent}" />
            <Setter Property="Foreground" Value="#0F1115" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding"    Value="18,9" />
            <Setter Property="Cursor"     Value="Hand" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b" Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="#74C0FC" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="b" Property="Background" Value="#3B96D8" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="BtnGhost" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{StaticResource text.muted}" />
            <Setter Property="Padding"    Value="18,9" />
            <Setter Property="Cursor"     Value="Hand" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="{StaticResource border.strong}" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="#22262F" />
                                <Setter Property="Foreground" Value="{StaticResource text}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!-- Window-chrome icon button (close, minimize) -->
        <Style x:Key="ChromeBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{StaticResource text.muted}" />
            <Setter Property="Width" Value="40" />
            <Setter Property="Height" Value="32" />
            <Setter Property="FontFamily" Value="Segoe Fluent Icons,Segoe MDL2 Assets" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="b" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="#22262F" />
                                <Setter Property="Foreground" Value="{StaticResource text}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ChromeBtnClose" TargetType="Button" BasedOn="{StaticResource ChromeBtn}">
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#C42B1C" />
                    <Setter Property="Foreground" Value="White" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ====== Inputs ====== -->
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource bg.input}" />
            <Setter Property="Foreground" Value="{StaticResource text}" />
            <Setter Property="BorderBrush" Value="{StaticResource border}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding"    Value="10,8" />
            <Setter Property="MinHeight"  Value="36" />
            <Setter Property="CaretBrush" Value="{StaticResource accent}" />
            <Setter Property="SelectionBrush" Value="{StaticResource accent.soft}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="b" CornerRadius="6"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="b" Property="BorderBrush" Value="{StaticResource accent}" />
                                <Setter TargetName="b" Property="Background" Value="{StaticResource bg.input.focus}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="PasswordBox">
            <Setter Property="Background" Value="{StaticResource bg.input}" />
            <Setter Property="Foreground" Value="{StaticResource text}" />
            <Setter Property="BorderBrush" Value="{StaticResource border}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding"    Value="10,8" />
            <Setter Property="MinHeight"  Value="36" />
            <Setter Property="CaretBrush" Value="{StaticResource accent}" />
        </Style>
        <!-- ComboBox: dark surface with light text. The default WPF ComboBox
             template paints its toggle-button background and selection-box
             from system brushes that don't follow Background/Foreground on the
             style; we override the template completely so the closed control
             AND the popup list match the rest of the dark Setup chrome. -->
        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="{StaticResource bg.input}" />
            <Setter Property="Foreground" Value="{StaticResource text}" />
            <Setter Property="BorderBrush" Value="{StaticResource border}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="MinHeight" Value="36" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border x:Name="MainBorder"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="6" />
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="28" />
                                </Grid.ColumnDefinitions>
                                <ContentPresenter x:Name="ContentSite"
                                                  Grid.Column="0"
                                                  Content="{TemplateBinding SelectionBoxItem}"
                                                  ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                  ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                                  Margin="{TemplateBinding Padding}"
                                                  HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                  VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                                  IsHitTestVisible="False"
                                                  TextElement.Foreground="{TemplateBinding Foreground}" />
                                <Path Grid.Column="1"
                                      Data="M 0,0 L 8,0 L 4,5 Z"
                                      Fill="{StaticResource text.muted}"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"
                                      IsHitTestVisible="False" />
                            </Grid>
                            <ToggleButton x:Name="DropDownToggle"
                                          Background="Transparent"
                                          BorderThickness="0"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          ClickMode="Press"
                                          Focusable="False">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="Transparent" />
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <Popup x:Name="Popup"
                                   Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Slide">
                                <Border Background="{StaticResource bg.input}"
                                        BorderBrush="{StaticResource border}"
                                        BorderThickness="1"
                                        CornerRadius="6"
                                        MinWidth="{TemplateBinding ActualWidth}"
                                        MaxHeight="320"
                                        Margin="0,4,0,0">
                                    <Border.Effect>
                                        <DropShadowEffect Color="Black" BlurRadius="14" ShadowDepth="0" Opacity="0.4" />
                                    </Border.Effect>
                                    <ScrollViewer Margin="2"
                                                  VerticalScrollBarVisibility="Auto">
                                        <StackPanel IsItemsHost="True"
                                                    KeyboardNavigation.DirectionalNavigation="Contained" />
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="MainBorder" Property="BorderBrush" Value="{StaticResource accent}" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="MainBorder" Property="BorderBrush" Value="{StaticResource border.strong}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ComboBoxItem">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{StaticResource text}" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="ItemBorder"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{StaticResource accent.soft}" />
                            </Trigger>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{StaticResource accent}" />
                                <Setter Property="Foreground" Value="#0F1115" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="RadioButton" x:Key="LangRadio">
            <Setter Property="Foreground" Value="{StaticResource text}" />
            <Setter Property="Margin" Value="0,0,16,0" />
        </Style>
        <!-- Implicit RadioButton style. WPF default Foreground is
             SystemColors.ControlText (black), which renders unreadable on
             the dark Setup chrome. Affects every RadioButton that doesn't
             pick its own keyed style (e.g. the Privacy mode picker). -->
        <Style TargetType="RadioButton">
            <Setter Property="Foreground" Value="{StaticResource text}" />
        </Style>
        <!-- Same reason for CheckBox: default text is system black. -->
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource text}" />
        </Style>

        <!-- ====== Section / labels ====== -->
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource text.muted}" />
            <Setter Property="FontSize"   Value="12" />
            <Setter Property="Margin"     Value="0,0,0,6" />
        </Style>
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource text}" />
            <Setter Property="FontSize"   Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin"     Value="0,0,0,12" />
        </Style>
        <Style x:Key="SectionDescription" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource text.muted}" />
            <Setter Property="FontSize"   Value="12" />
            <Setter Property="Margin"     Value="0,0,0,18" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>
        <Style x:Key="PageTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="26" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource text}" />
        </Style>
        <Style x:Key="PageSubtitle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource text.muted}" />
            <Setter Property="Margin" Value="0,4,0,24" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource bg.card}" />
            <Setter Property="BorderBrush" Value="{StaticResource border}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="22" />
            <Setter Property="Margin" Value="0,0,0,16" />
        </Style>

        <!-- ====== DataGrid (modern) ====== -->
        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{StaticResource text}" />
            <Setter Property="BorderBrush" Value="{StaticResource border}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="GridLinesVisibility" Value="Horizontal" />
            <Setter Property="HorizontalGridLinesBrush" Value="{StaticResource border}" />
            <Setter Property="VerticalGridLinesBrush" Value="Transparent" />
            <Setter Property="RowBackground" Value="Transparent" />
            <Setter Property="AlternatingRowBackground" Value="#1F242C" />
            <Setter Property="HeadersVisibility" Value="Column" />
            <Setter Property="RowHeight" Value="34" />
        </Style>
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="{StaticResource bg.subtle}" />
            <Setter Property="Foreground" Value="{StaticResource text.muted}" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="BorderBrush" Value="{StaticResource border}" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
        </Style>
        <Style TargetType="DataGridCell">
            <Setter Property="Foreground" Value="{StaticResource text}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Padding" Value="12,6" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{StaticResource accent.soft}" />
                    <Setter Property="Foreground" Value="{StaticResource text}" />
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="DataGridRow">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{StaticResource text}" />
        </Style>

        <!-- ====== Custom dark scrollbars ====== -->
        <Style x:Key="ScrollThumb" TargetType="Thumb">
            <Setter Property="Background" Value="#3A4051" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border x:Name="b" CornerRadius="4"
                                Background="{TemplateBinding Background}" Margin="3,2" />
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="Background" Value="#4F5667" />
                            </Trigger>
                            <Trigger Property="IsDragging" Value="True">
                                <Setter TargetName="b" Property="Background" Value="#5C6478" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ScrollPageButton" TargetType="RepeatButton">
            <Setter Property="IsTabStop" Value="False" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RepeatButton">
                        <Border Background="Transparent" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ScrollBar">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Style.Triggers>
                <Trigger Property="Orientation" Value="Vertical">
                    <Setter Property="Width" Value="10" />
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ScrollBar">
                                <Grid>
                                    <Border Background="Transparent" />
                                    <Track x:Name="PART_Track" IsDirectionReversed="True">
                                        <Track.DecreaseRepeatButton>
                                            <RepeatButton Style="{StaticResource ScrollPageButton}" Command="ScrollBar.PageUpCommand" />
                                        </Track.DecreaseRepeatButton>
                                        <Track.Thumb>
                                            <Thumb Style="{StaticResource ScrollThumb}" />
                                        </Track.Thumb>
                                        <Track.IncreaseRepeatButton>
                                            <RepeatButton Style="{StaticResource ScrollPageButton}" Command="ScrollBar.PageDownCommand" />
                                        </Track.IncreaseRepeatButton>
                                    </Track>
                                </Grid>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Trigger>
                <Trigger Property="Orientation" Value="Horizontal">
                    <Setter Property="Height" Value="10" />
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ScrollBar">
                                <Grid>
                                    <Border Background="Transparent" />
                                    <Track x:Name="PART_Track">
                                        <Track.DecreaseRepeatButton>
                                            <RepeatButton Style="{StaticResource ScrollPageButton}" Command="ScrollBar.PageLeftCommand" />
                                        </Track.DecreaseRepeatButton>
                                        <Track.Thumb>
                                            <Thumb Style="{StaticResource ScrollThumb}" />
                                        </Track.Thumb>
                                        <Track.IncreaseRepeatButton>
                                            <RepeatButton Style="{StaticResource ScrollPageButton}" Command="ScrollBar.PageRightCommand" />
                                        </Track.IncreaseRepeatButton>
                                    </Track>
                                </Grid>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ====== Toggle switch for booleans ====== -->
        <Style x:Key="ToggleSwitch" TargetType="CheckBox">
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Foreground" Value="{StaticResource text}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <StackPanel Orientation="Horizontal">
                            <Border x:Name="track" Width="38" Height="22" CornerRadius="11"
                                    Background="#2D3340" BorderBrush="{StaticResource border}" BorderThickness="1">
                                <Border x:Name="knob" Width="16" Height="16" CornerRadius="8"
                                        Background="#8B95A7" HorizontalAlignment="Left" Margin="2,0,0,0" />
                            </Border>
                            <ContentPresenter Margin="10,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="track" Property="Background" Value="{StaticResource accent}" />
                                <Setter TargetName="track" Property="BorderBrush" Value="{StaticResource accent}" />
                                <Setter TargetName="knob" Property="HorizontalAlignment" Value="Right" />
                                <Setter TargetName="knob" Property="Margin" Value="0,0,2,0" />
                                <Setter TargetName="knob" Property="Background" Value="#0F1115" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="track" Property="BorderBrush" Value="{StaticResource border.strong}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Grid-size choice cards -->
        <Style x:Key="GridChoice" TargetType="RadioButton">
            <Setter Property="Foreground" Value="{StaticResource text.muted}" />
            <Setter Property="Background" Value="{StaticResource bg.input}" />
            <Setter Property="BorderBrush" Value="{StaticResource border}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Margin" Value="0,0,12,0" />
            <Setter Property="MinWidth" Value="140" />
            <Setter Property="MinHeight" Value="120" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="b"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                Padding="20">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="b" Property="BorderBrush" Value="{StaticResource border.strong}" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="b" Property="Background" Value="{StaticResource accent.soft}" />
                                <Setter TargetName="b" Property="BorderBrush" Value="{StaticResource accent}" />
                                <Setter Property="Foreground" Value="{StaticResource accent}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- =============== Outer rounded container with subtle shadow =============== -->
    <Border Background="{StaticResource bg.canvas}"
            BorderBrush="{StaticResource border}"
            BorderThickness="1"
            CornerRadius="18"
            Margin="14"
            ClipToBounds="True">
        <Border.Effect>
            <DropShadowEffect Color="Black" BlurRadius="22" ShadowDepth="0" Opacity="0.6" />
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- =============== Title bar (drag region + chrome buttons) =============== -->
            <Grid Grid.Row="0" x:Name="TitleBar" Height="36"
                  Background="Transparent"
                  MouseLeftButtonDown="OnTitleBarMouseDown">
                <TextBlock Text="{local:Loc SetupTitle}"
                           Foreground="{StaticResource text.muted}"
                           FontSize="12"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Left"
                           Margin="20,0,0,0" />
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="&#xE921;" Style="{StaticResource ChromeBtn}" Click="OnMinimize" />
                    <Button Content="&#xE8BB;" Style="{StaticResource ChromeBtnClose}" Click="OnClose" />
                </StackPanel>
            </Grid>

            <!-- =============== Body =============== -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="240" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- ============== Sidebar ============== -->
                <Border Grid.Column="0" Background="{StaticResource bg.sidebar}">
                    <DockPanel>
                        <Border DockPanel.Dock="Top" Padding="20,16,20,18">
                            <StackPanel>
                                <TextBlock Text="Setup" FontSize="22" FontWeight="SemiBold" />
                                <TextBlock Text="{local:Loc SetupBrandSub}"
                                           Foreground="{StaticResource text.muted}" FontSize="12" Margin="0,2,0,0"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>

                        <Border DockPanel.Dock="Top" BorderBrush="{StaticResource border}"
                                BorderThickness="0,1,0,0" Margin="14,0" />

                        <Border DockPanel.Dock="Bottom" Padding="20,18">
                            <StackPanel x:Name="ConnPanel" Orientation="Horizontal">
                                <Border x:Name="ConnDot" Width="8" Height="8" CornerRadius="4"
                                        Background="{StaticResource text.dim}"
                                        VerticalAlignment="Center" Margin="0,0,8,0" />
                                <TextBlock x:Name="ConnText" Text=""
                                           Foreground="{StaticResource text.muted}" FontSize="12"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                        </Border>

                        <StackPanel Margin="0,12,0,0">
                            <RadioButton x:Name="NavNvr" Style="{StaticResource NavItem}" IsChecked="True"
                                         Tag="NvrPanel" Checked="OnNavChecked">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xEC15;" FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets" FontSize="16" Margin="0,0,12,0" />
                                    <TextBlock Text="{local:Loc NavNvr}" FontSize="13" />
                                </StackPanel>
                            </RadioButton>
                            <RadioButton x:Name="NavCameras" Style="{StaticResource NavItem}"
                                         Tag="CamerasPanel" Checked="OnNavChecked">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE722;" FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets" FontSize="16" Margin="0,0,12,0" />
                                    <TextBlock Text="{local:Loc NavCameras}" FontSize="13" />
                                </StackPanel>
                            </RadioButton>
                            <RadioButton x:Name="NavPrivacy" Style="{StaticResource NavItem}"
                                         Tag="PrivacyPanel" Checked="OnNavChecked">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE72E;" FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets" FontSize="16" Margin="0,0,12,0" />
                                    <TextBlock Text="{local:Loc NavPrivacy}" FontSize="13" />
                                </StackPanel>
                            </RadioButton>
                            <RadioButton x:Name="NavWeb" Style="{StaticResource NavItem}"
                                         Tag="WebPanel" Checked="OnNavChecked">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE968;" FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets" FontSize="16" Margin="0,0,12,0" />
                                    <TextBlock Text="{local:Loc NavWeb}" FontSize="13" />
                                </StackPanel>
                            </RadioButton>
                            <RadioButton x:Name="NavAudit" Style="{StaticResource NavItem}"
                                         Tag="AuditPanel" Checked="OnNavChecked">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE9D9;" FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets" FontSize="16" Margin="0,0,12,0" />
                                    <TextBlock Text="{local:Loc NavAudit}" FontSize="13" />
                                </StackPanel>
                            </RadioButton>
                            <RadioButton x:Name="NavAdmin" Style="{StaticResource NavItem}"
                                         Tag="AdminPanel" Checked="OnNavChecked">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE77B;" FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets" FontSize="16" Margin="0,0,12,0" />
                                    <TextBlock Text="{local:Loc NavAdmin}" FontSize="13" />
                                </StackPanel>
                            </RadioButton>
                            <RadioButton x:Name="NavAbout" Style="{StaticResource NavItem}"
                                         Tag="AboutPanel" Checked="OnNavChecked">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE946;" FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets" FontSize="16" Margin="0,0,12,0" />
                                    <TextBlock Text="{local:Loc NavAbout}" FontSize="13" />
                                </StackPanel>
                            </RadioButton>
                        </StackPanel>
                    </DockPanel>
                </Border>

                <!-- ============== Content area ============== -->
                <Grid Grid.Column="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" Padding="36,28,36,12">
                        <Grid>

                            <!-- ============================ NVR ============================ -->
                            <StackPanel x:Name="NvrPanel">
                                <TextBlock Text="{local:Loc NvrPageTitle}" Style="{StaticResource PageTitle}" />
                                <TextBlock Text="{local:Loc NvrPageSubtitle}" Style="{StaticResource PageSubtitle}" />

                                <Border Style="{StaticResource Card}">
                                    <StackPanel>
                                        <Grid>
                                            <TextBlock Text="{local:Loc NvrCardConnection}" Style="{StaticResource SectionHeader}" />
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                                <Button Content="{local:Loc NvrAddRow}" Style="{StaticResource BtnGhost}" Click="OnAddNvrRow" />
                                            </StackPanel>
                                        </Grid>
                                        <DataGrid x:Name="NvrGrid"
                                                  AutoGenerateColumns="False"
                                                  CanUserAddRows="False"
                                                  CanUserDeleteRows="False"
                                                  IsReadOnly="True"
                                                  SelectionMode="Single"
                                                  HeadersVisibility="Column"
                                                  Height="240"
                                                  Margin="0,4,0,0"
                                                  MouseDoubleClick="OnNvrRowDoubleClick">
                                            <DataGrid.Columns>
                                                <DataGridTextColumn Binding="{Binding Name}" Width="160">
                                                    <DataGridTextColumn.Header><TextBlock Text="{local:Loc NvrHeaderName}" /></DataGridTextColumn.Header>
                                                </DataGridTextColumn>
                                                <DataGridTextColumn Binding="{Binding Ip}" Width="160">
                                                    <DataGridTextColumn.Header><TextBlock Text="{local:Loc NvrFieldIp}" /></DataGridTextColumn.Header>
                                                </DataGridTextColumn>
                                                <DataGridTextColumn Binding="{Binding Port}" Width="80">
                                                    <DataGridTextColumn.Header><TextBlock Text="{local:Loc NvrFieldPort}" /></DataGridTextColumn.Header>
                                                </DataGridTextColumn>
                                                <DataGridTextColumn Binding="{Binding User}" Width="140">
                                                    <DataGridTextColumn.Header><TextBlock Text="{local:Loc NvrFieldUser}" /></DataGridTextColumn.Header>
                                                </DataGridTextColumn>
                                                <DataGridTemplateColumn Width="*" CanUserSort="False">
                                                    <DataGridTemplateColumn.Header>
                                                        <TextBlock Text="{local:Loc NvrFieldPassword}" />
                                                    </DataGridTemplateColumn.Header>
                                                    <DataGridTemplateColumn.CellTemplate>
                                                        <DataTemplate>
                                                            <!-- Render password as static dots so the user sees "is set" / "is empty"
                                                                 without exposing the actual value or trying to in-cell edit. -->
                                                            <TextBlock VerticalAlignment="Center"
                                                                       Foreground="{StaticResource text.muted}"
                                                                       FontFamily="Consolas"
                                                                       Padding="6,0">
                                                                <TextBlock.Style>
                                                                    <Style TargetType="TextBlock">
                                                                        <Setter Property="Text" Value="••••••••" />
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding Password}" Value="">
                                                                                <Setter Property="Text" Value="—" />
                                                                            </DataTrigger>
                                                                            <DataTrigger Binding="{Binding Password}" Value="{x:Null}">
                                                                                <Setter Property="Text" Value="—" />
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </TextBlock.Style>
                                                            </TextBlock>
                                                        </DataTemplate>
                                                    </DataGridTemplateColumn.CellTemplate>
                                                </DataGridTemplateColumn>
                                                <DataGridTemplateColumn Width="80" CanUserSort="False" CanUserResize="False" CanUserReorder="False">
                                                    <DataGridTemplateColumn.Header><TextBlock Text="" /></DataGridTemplateColumn.Header>
                                                    <DataGridTemplateColumn.CellTemplate>
                                                        <DataTemplate>
                                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                                <Button Click="OnEditNvrRow"
                                                                        Background="Transparent" BorderThickness="0"
                                                                        Foreground="{StaticResource text.muted}"
                                                                        FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                                                                        FontSize="14" Cursor="Hand" Padding="0"
                                                                        Width="28" Height="28"
                                                                        ToolTip="{local:Loc NvrEditRowTooltip}"
                                                                        Content="&#xE70F;" />
                                                                <Button Click="OnDeleteNvrRow"
                                                                        Background="Transparent" BorderThickness="0"
                                                                        Foreground="{StaticResource text.muted}"
                                                                        FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                                                                        FontSize="14" Cursor="Hand" Padding="0"
                                                                        Width="28" Height="28"
                                                                        ToolTip="{local:Loc NvrDeleteRowTooltip}"
                                                                        Content="&#xE74D;" />
                                                            </StackPanel>
                                                        </DataTemplate>
                                                    </DataGridTemplateColumn.CellTemplate>
                                                </DataGridTemplateColumn>
                                            </DataGrid.Columns>
                                        </DataGrid>
                                        <Border Background="#1A2331" BorderBrush="#22324A" BorderThickness="1"
                                                CornerRadius="6" Padding="12,10" Margin="0,12,0,0">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="&#xE946;" FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                                                           Foreground="{StaticResource accent}" Margin="0,0,8,0" VerticalAlignment="Top" />
                                                <TextBlock Foreground="{StaticResource text.muted}" FontSize="12" TextWrapping="Wrap"
                                                           Text="{local:Loc NvrMultiHint}" />
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </Border>

                                <!-- ===== Grid-grootte (samengevoegd in NVR-tab v1.3.0) ===== -->
                                <Border Style="{StaticResource Card}">
                                    <StackPanel>
                                        <TextBlock Text="{local:Loc GridCardSize}" Style="{StaticResource SectionHeader}" />
                                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                            <RadioButton x:Name="Grid1" Style="{StaticResource GridChoice}" GroupName="GridSize">
                                                <StackPanel HorizontalAlignment="Center">
                                                    <TextBlock Text="1 x 1" FontSize="22" FontWeight="SemiBold" HorizontalAlignment="Center" />
                                                    <TextBlock Text="{local:Loc GridChoice1Caption}" Foreground="{StaticResource text.muted}" FontSize="11" Margin="0,4,0,0" HorizontalAlignment="Center" />
                                                </StackPanel>
                                            </RadioButton>
                                            <RadioButton x:Name="Grid2" Style="{StaticResource GridChoice}" GroupName="GridSize">
                                                <StackPanel HorizontalAlignment="Center">
                                                    <TextBlock Text="2 x 2" FontSize="22" FontWeight="SemiBold" HorizontalAlignment="Center" />
                                                    <TextBlock Text="{local:Loc GridChoice4Caption}" Foreground="{StaticResource text.muted}" FontSize="11" Margin="0,4,0,0" HorizontalAlignment="Center" />
                                                </StackPanel>
                                            </RadioButton>
                                            <RadioButton x:Name="Grid3" Style="{StaticResource GridChoice}" GroupName="GridSize">
                                                <StackPanel HorizontalAlignment="Center">
                                                    <TextBlock Text="3 x 3" FontSize="22" FontWeight="SemiBold" HorizontalAlignment="Center" />
                                                    <TextBlock Text="{local:Loc GridChoice9Caption}" Foreground="{StaticResource text.muted}" FontSize="11" Margin="0,4,0,0" HorizontalAlignment="Center" />
                                                </StackPanel>
                                            </RadioButton>
                                            <RadioButton x:Name="Grid4" Style="{StaticResource GridChoice}" GroupName="GridSize">
                                                <StackPanel HorizontalAlignment="Center">
                                                    <TextBlock Text="4 x 4" FontSize="22" FontWeight="SemiBold" HorizontalAlignment="Center" />
                                                    <TextBlock Text="{local:Loc GridChoice16Caption}" Foreground="{StaticResource text.muted}" FontSize="11" Margin="0,4,0,0" HorizontalAlignment="Center" />
                                                </StackPanel>
                                            </RadioButton>
                                            <RadioButton x:Name="Grid5" Style="{StaticResource GridChoice}" GroupName="GridSize">
                                                <StackPanel HorizontalAlignment="Center">
                                                    <TextBlock Text="5 x 5" FontSize="22" FontWeight="SemiBold" HorizontalAlignment="Center" />
                                                    <TextBlock Text="{local:Loc GridChoice25Caption}" Foreground="{StaticResource text.muted}" FontSize="11" Margin="0,4,0,0" HorizontalAlignment="Center" />
                                                </StackPanel>
                                            </RadioButton>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </StackPanel>

                            <!-- ============================ Cameras ============================ -->
                            <StackPanel x:Name="CamerasPanel" Visibility="Collapsed">
                                <TextBlock Text="{local:Loc CamerasPageTitle}" Style="{StaticResource PageTitle}" />
                                <TextBlock Text="{local:Loc CamerasPageSubtitle}" Style="{StaticResource PageSubtitle}" />

                                <Border Style="{StaticResource Card}">
                                    <StackPanel>
                                        <Grid>
                                            <TextBlock Text="{local:Loc CamerasCardBindings}" Style="{StaticResource SectionHeader}" />
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                                <Button Content="{local:Loc CamerasSyncNames}" Style="{StaticResource BtnGhost}" Click="OnSyncCameraNames" Margin="0,0,8,0" />
                                                <Button Content="{local:Loc CamerasAddRow}" Style="{StaticResource BtnGhost}" Click="OnAddCameraRow" />
                                            </StackPanel>
                                        </Grid>
                                        <DataGrid x:Name="CameraGrid"
                                                  AutoGenerateColumns="False"
                                                  CanUserAddRows="True"
                                                  CanUserDeleteRows="True"
                                                  SelectionMode="Single"
                                                  HeadersVisibility="Column"
                                                  Height="600"
                                                  Margin="0,4,0,0"
                                                  AllowDrop="True"
                                                  Drop="OnCameraGridDrop"
                                                  DragOver="OnCameraGridDragOver">
                                            <DataGrid.Resources>
                                                <local:IntPlusOneConverter x:Key="OneBased" />
                                            </DataGrid.Resources>
                                            <DataGrid.Columns>
                                                <!-- Drag handle column. Grip icon, when held with the left mouse
                                                     button you can drag the row up or down to reorder. The Slot
                                                     column auto-renumbers on drop. -->
                                                <DataGridTemplateColumn Width="32" CanUserSort="False" CanUserResize="False" CanUserReorder="False">
                                                    <DataGridTemplateColumn.Header><TextBlock Text="" /></DataGridTemplateColumn.Header>
                                                    <DataGridTemplateColumn.CellTemplate>
                                                        <DataTemplate>
                                                            <TextBlock Text="&#xE76F;"
                                                                       FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                                                                       FontSize="14"
                                                                       Foreground="{StaticResource text.muted}"
                                                                       HorizontalAlignment="Center"
                                                                       VerticalAlignment="Center"
                                                                       Cursor="SizeNS"
                                                                       PreviewMouseLeftButtonDown="OnCameraGripMouseDown"
                                                                       MouseMove="OnCameraGripMouseMove"
                                                                       ToolTip="{local:Loc CamerasReorderTooltip}" />
                                                        </DataTemplate>
                                                    </DataGridTemplateColumn.CellTemplate>
                                                </DataGridTemplateColumn>
                                                <DataGridTextColumn Binding="{Binding Slot, Converter={StaticResource OneBased}}" Width="70" IsReadOnly="True">
                                                    <DataGridTextColumn.Header><TextBlock Text="{local:Loc CamerasHeaderSlot}" /></DataGridTextColumn.Header>
                                                </DataGridTextColumn>
                                                <DataGridComboBoxColumn x:Name="NvrColumn"
                                                                        SelectedValueBinding="{Binding NvrId, UpdateSourceTrigger=PropertyChanged}"
                                                                        SelectedValuePath="Id"
                                                                        DisplayMemberPath="Name"
                                                                        Width="140">
                                                    <DataGridComboBoxColumn.Header><TextBlock Text="{local:Loc CamerasHeaderNvr}" /></DataGridComboBoxColumn.Header>
                                                </DataGridComboBoxColumn>
                                                <DataGridTextColumn Binding="{Binding CameraIndex, Converter={StaticResource OneBased}}" Width="90">
                                                    <DataGridTextColumn.Header><TextBlock Text="{local:Loc CamerasHeaderCameraIndex}" /></DataGridTextColumn.Header>
                                                </DataGridTextColumn>
                                                <DataGridComboBoxColumn x:Name="StreamColumn"
                                                                        SelectedValueBinding="{Binding StreamId, UpdateSourceTrigger=PropertyChanged}"
                                                                        SelectedValuePath="Value"
                                                                        DisplayMemberPath="Display"
                                                                        Width="110">
                                                    <DataGridComboBoxColumn.Header><TextBlock Text="{local:Loc CamerasHeaderStream}" /></DataGridComboBoxColumn.Header>
                                                </DataGridComboBoxColumn>
                                                <!-- Read-only: filled by the Pull-names sync. NVR is the source of
                                                     truth, so editing this here would just be overwritten next sync. -->
                                                <DataGridTextColumn Binding="{Binding NvrTitle}" Width="*" IsReadOnly="True">
                                                    <DataGridTextColumn.Header><TextBlock Text="{local:Loc CamerasHeaderNvrTitle}" /></DataGridTextColumn.Header>
                                                </DataGridTextColumn>
                                                <DataGridTextColumn Binding="{Binding Label}" Width="*">
                                                    <DataGridTextColumn.Header><TextBlock Text="{local:Loc CamerasHeaderLabel}" /></DataGridTextColumn.Header>
                                                </DataGridTextColumn>
                                                <!-- v2.0 AI column: button opens a small modal with the per-camera
                                                     AI toggle plus the three masking categories. Width is fixed; the
                                                     button text is short ("AI..." in the active locale) so the column
                                                     stays compact. -->
                                                <DataGridTemplateColumn Width="68" CanUserSort="False" CanUserResize="False" CanUserReorder="False">
                                                    <DataGridTemplateColumn.Header>
                                                        <TextBlock Text="{local:Loc CameraColumnAi}" />
                                                    </DataGridTemplateColumn.Header>
                                                    <DataGridTemplateColumn.CellTemplate>
                                                        <DataTemplate>
                                                            <!-- State-aware AI button. Default (AI ON) takes the same solid
                                                                 bright-accent look as the primary Save button at the bottom
                                                                 of Setup so it pops out unmistakably from the row content.
                                                                 When AI is off the button collapses to a muted ghost so the
                                                                 admin can scan the camera list and tell at a glance which
                                                                 feeds are using compute. CornerRadius=6 matches BtnPrimary
                                                                 and the rest of the app chrome (cards, NVR dialog buttons). -->
                                                            <Button Click="OnCameraAiButton"
                                                                    Content="{local:Loc CameraButtonAi}"
                                                                    Padding="8,3"
                                                                    FontSize="10"
                                                                    FontWeight="SemiBold"
                                                                    Cursor="Hand"
                                                                    HorizontalAlignment="Center"
                                                                    VerticalAlignment="Center"
                                                                    FocusVisualStyle="{x:Null}">
                                                                <Button.Template>
                                                                    <ControlTemplate TargetType="Button">
                                                                        <Border x:Name="b"
                                                                                Background="{TemplateBinding Background}"
                                                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                                                CornerRadius="6"
                                                                                Padding="{TemplateBinding Padding}">
                                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                                        </Border>
                                                                        <ControlTemplate.Triggers>
                                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                                <Setter TargetName="b" Property="Opacity" Value="0.85" />
                                                                            </Trigger>
                                                                            <Trigger Property="IsPressed" Value="True">
                                                                                <Setter TargetName="b" Property="Opacity" Value="0.7" />
                                                                            </Trigger>
                                                                        </ControlTemplate.Triggers>
                                                                    </ControlTemplate>
                                                                </Button.Template>
                                                                <Button.Style>
                                                                    <Style TargetType="Button">
                                                                        <!-- Default = AI ON: solid accent fill, dark text. -->
                                                                        <Setter Property="Background" Value="{StaticResource accent}" />
                                                                        <Setter Property="Foreground" Value="#0F1115" />
                                                                        <Setter Property="BorderThickness" Value="0" />
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding AiEnabled}" Value="False">
                                                                                <!-- AI OFF: ghost, clearly de-emphasised. -->
                                                                                <Setter Property="Background" Value="Transparent" />
                                                                                <Setter Property="Foreground" Value="{StaticResource text.muted}" />
                                                                                <Setter Property="BorderThickness" Value="1" />
                                                                                <Setter Property="BorderBrush" Value="{StaticResource border}" />
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </Button.Style>
                                                            </Button>
                                                        </DataTemplate>
                                                    </DataGridTemplateColumn.CellTemplate>
                                                </DataGridTemplateColumn>
                                                <!-- Delete column: trashcan-icon button per row, right-aligned, more
                                                     discoverable than relying on the Del key. -->
                                                <DataGridTemplateColumn Width="44" CanUserSort="False" CanUserResize="False" CanUserReorder="False">
                                                    <DataGridTemplateColumn.Header>
                                                        <TextBlock Text="" />
                                                    </DataGridTemplateColumn.Header>
                                                    <DataGridTemplateColumn.CellTemplate>
                                                        <DataTemplate>
                                                            <Button Click="OnDeleteCameraRow"
                                                                    Background="Transparent"
                                                                    BorderThickness="0"
                                                                    Foreground="{StaticResource text.muted}"
                                                                    FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                                                                    FontSize="14"
                                                                    Cursor="Hand"
                                                                    Padding="0"
                                                                    Width="28" Height="28"
                                                                    HorizontalAlignment="Center"
                                                                    VerticalAlignment="Center"
                                                                    ToolTip="{local:Loc CamerasDeleteRowTooltip}"
                                                                    Content="&#xE74D;" />
                                                        </DataTemplate>
                                                    </DataGridTemplateColumn.CellTemplate>
                                                </DataGridTemplateColumn>
                                            </DataGrid.Columns>
                                        </DataGrid>
                                        <TextBlock Foreground="{StaticResource text.muted}" FontSize="12" Margin="0,12,0,0"
                                                   TextWrapping="Wrap"
                                                   Text="{local:Loc CamerasHelpText}" />
                                    </StackPanel>
                                </Border>
                            </StackPanel>

                            <!-- Grid panel removed in v1.3.0 — content moved into NvrPanel
                                 because the previous tab held a single small card and felt
                                 like padding. -->

                            <!-- ============================ Privacy ============================ -->
                            <StackPanel x:Name="PrivacyPanel" Visibility="Collapsed">
                                <TextBlock Text="{local:Loc PrivacyPageTitle}" Style="{StaticResource PageTitle}" />
                                <TextBlock Text="{local:Loc PrivacyPageSubtitle}" Style="{StaticResource PageSubtitle}" />

                                <!-- ===== Default visibility mode ===== -->
                                <Border Style="{StaticResource Card}">
                                    <StackPanel>
                                        <TextBlock Text="{local:Loc PrivacyCardMode}" Style="{StaticResource SectionHeader}" />
                                        <RadioButton x:Name="ModeOversightRadio" GroupName="PrivacyMode" Margin="0,8,0,4">
                                            <StackPanel>
                                                <TextBlock Text="{local:Loc PrivacyModeOversightLabel}" FontWeight="SemiBold" />
                                                <TextBlock Text="{local:Loc PrivacyModeOversightHelp}"
                                                           Foreground="{StaticResource text.muted}"
                                                           FontSize="12"
                                                           TextWrapping="Wrap"
                                                           Margin="0,2,0,0" />
                                            </StackPanel>
                                        </RadioButton>
                                        <RadioButton x:Name="ModePrivacyRadio" GroupName="PrivacyMode" Margin="0,12,0,4">
                                            <StackPanel>
                                                <TextBlock Text="{local:Loc PrivacyModePrivacyLabel}" FontWeight="SemiBold" />
                                                <TextBlock Text="{local:Loc PrivacyModePrivacyHelp}"
                                                           Foreground="{StaticResource text.muted}"
                                                           FontSize="12"
                                                           TextWrapping="Wrap"
                                                           Margin="0,2,0,0" />
                                            </StackPanel>
                                        </RadioButton>
                                        <!-- Auth-on-reveal toggle, only meaningful in PrivacyDefault mode.
                                             Greyed out and ignored when OversightDefault is selected. -->
                                        <Grid Margin="0,16,0,0"
                                              IsEnabled="{Binding IsChecked, ElementName=ModePrivacyRadio}">
                                            <StackPanel>
                                                <TextBlock Text="{local:Loc PrivacyDefaultRequireAuthOnRevealLabel}"
                                                           Style="{StaticResource FieldLabel}" />
                                                <TextBlock Text="{local:Loc PrivacyDefaultRequireAuthOnRevealHelp}"
                                                           Foreground="{StaticResource text.muted}"
                                                           FontSize="12"
                                                           TextWrapping="Wrap" />
                                            </StackPanel>
                                            <CheckBox x:Name="PrivacyDefaultRequireAuthOnReveal"
                                                      Style="{StaticResource ToggleSwitch}"
                                                      HorizontalAlignment="Right"
                                                      VerticalAlignment="Top" />
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <!-- ===== Sessie-PIN ===== -->
                                <Border Style="{StaticResource Card}">
                                    <StackPanel>
                                        <Grid>
                                            <StackPanel>
                                                <TextBlock Text="{local:Loc PrivacyCardSessionPin}" Style="{StaticResource SectionHeader}" />
                                                <TextBlock Foreground="{StaticResource text.muted}" FontSize="12"
                                                           TextWrapping="Wrap"
                                                           Text="{local:Loc PrivacySessionPinHelp}" />
                                            </StackPanel>
                                            <CheckBox x:Name="RequireSessionPin"
                                                      Style="{StaticResource ToggleSwitch}"
                                                      HorizontalAlignment="Right"
                                                      VerticalAlignment="Top" />
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <!-- ===== Auto-uit timer ===== -->
                                <Border Style="{StaticResource Card}">
                                    <StackPanel>
                                        <TextBlock Text="{local:Loc PrivacyCardAutoOff}" Style="{StaticResource SectionHeader}" />
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="20" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="{local:Loc PrivacyAutoOffMinutesLabel}" Style="{StaticResource FieldLabel}" />
                                                <TextBox x:Name="AutoUnmaskMinutes" />
                                            </StackPanel>
                                            <StackPanel Grid.Column="2">
                                                <TextBlock Text="{local:Loc PrivacyWarningMinutesLabel}" Style="{StaticResource FieldLabel}" />
                                                <TextBox x:Name="WarningMinutes" />
                                            </StackPanel>
                                        </Grid>
                                        <TextBlock Foreground="{StaticResource text.muted}" FontSize="12" Margin="0,12,0,0"
                                                   TextWrapping="Wrap"
                                                   Text="{local:Loc PrivacyAutoOffExample}" />
                                    </StackPanel>
                                </Border>

                                <!-- ===== Long-press mass mask / unmask ===== -->
                                <Border Style="{StaticResource Card}">
                                    <StackPanel>
                                        <TextBlock Text="{local:Loc PrivacyCardMassMask}" Style="{StaticResource SectionHeader}" />
                                        <TextBlock Foreground="{StaticResource text.muted}" FontSize="12" Margin="0,0,0,12"
                                                   TextWrapping="Wrap"
                                                   Text="{local:Loc PrivacyLongPressHelp}" />
                                        <Grid>
                                            <StackPanel>
                                                <TextBlock Text="{local:Loc PrivacyShowMassUnmaskConfirmLabel}"
                                                           Style="{StaticResource FieldLabel}" />
                                                <TextBlock Foreground="{StaticResource text.muted}" FontSize="12"
                                                           TextWrapping="Wrap"
                                                           Text="{local:Loc PrivacyShowMassUnmaskConfirmHelp}" />
                                            </StackPanel>
                                            <CheckBox x:Name="ShowMassUnmaskConfirm"
                                                      Style="{StaticResource ToggleSwitch}"
                                                      HorizontalAlignment="Right"
                                                      VerticalAlignment="Top" />
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <!-- ===== Tile overlay (custom label + NVR title) ===== -->
                                <Border Style="{StaticResource Card}">
                                    <StackPanel>
                                        <TextBlock Text="{local:Loc PrivacyCardTileOverlay}" Style="{StaticResource SectionHeader}" />
                                        <Grid Margin="0,12,0,0">
                                            <StackPanel>
                                                <TextBlock Text="{local:Loc PrivacyShowCameraLabel}"
                                                           Style="{StaticResource FieldLabel}" />
                                                <TextBlock Foreground="{StaticResource text.muted}" FontSize="12"
                                                           TextWrapping="Wrap"
                                                           Text="{local:Loc PrivacyShowCameraLabelHelp}" />
                                            </StackPanel>
                                            <CheckBox x:Name="ShowCameraLabel"
                                                      Style="{StaticResource ToggleSwitch}"
                                                      HorizontalAlignment="Right"
                                                      VerticalAlignment="Top" />
                                        </Grid>
                                        <Grid Margin="0,16,0,0">
                                            <StackPanel>
                                                <TextBlock Text="{local:Loc PrivacyShowNvrTitle}"
                                                           Style="{StaticResource FieldLabel}" />
                                                <TextBlock Foreground="{StaticResource text.muted}" FontSize="12"
                                                           TextWrapping="Wrap"
                                                           Text="{local:Loc PrivacyShowNvrTitleHelp}" />
                                            </StackPanel>
                                            <CheckBox x:Name="ShowNvrTitle"
                                                      Style="{StaticResource ToggleSwitch}"
                                                      HorizontalAlignment="Right"
                                                      VerticalAlignment="Top" />
                                        </Grid>
                                    </StackPanel>
                                </Border>
                            </StackPanel>

                            <!-- ============================ Web-UI ============================ -->
                            <StackPanel x:Name="WebPanel" Visibility="Collapsed">
                                <TextBlock Text="{local:Loc WebPageTitle}" Style="{StaticResource PageTitle}" />
                                <TextBlock Text="{local:Loc WebPageSubtitle}" Style="{StaticResource PageSubtitle}" />

                                <!-- ===== Poorten + bind ===== -->
                                <Border Style="{StaticResource Card}">
                                    <StackPanel>
                                        <TextBlock Text="{local:Loc WebCardPorts}" Style="{StaticResource SectionHeader}" />
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="20" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="{local:Loc WebHttpPortLabel}" Style="{StaticResource FieldLabel}" />
                                                <TextBox x:Name="HttpPort" />
                                            </StackPanel>
                                            <StackPanel Grid.Column="2">
                                                <TextBlock Text="{local:Loc WebHttpsPortLabel}" Style="{StaticResource FieldLabel}" />
                                                <TextBox x:Name="HttpsPort" />
                                            </StackPanel>
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <!-- ===== Cross-machine binding ===== -->
                                <Border Style="{StaticResource Card}">
                                    <Grid>
                                        <StackPanel>
                                            <TextBlock Text="{local:Loc WebCardLan}" Style="{StaticResource SectionHeader}" />
                                            <TextBlock Foreground="{StaticResource text.muted}" FontSize="12"
                                                       TextWrapping="Wrap"
                                                       Text="{local:Loc WebLanHelp}" />
                                        </StackPanel>
                                        <CheckBox x:Name="BindAllInterfaces"
                                                  Style="{StaticResource ToggleSwitch}"
                                                  HorizontalAlignment="Right"
                                                  VerticalAlignment="Top" />
                                    </Grid>
                                </Border>

                                <!-- ===== Certificaat ===== -->
                                <Border Style="{StaticResource Card}">
                                    <StackPanel>
                                        <TextBlock Text="{local:Loc WebCardCert}" Style="{StaticResource SectionHeader}" />
                                        <TextBlock Foreground="{StaticResource text.muted}" FontSize="12" Margin="0,0,0,12"
                                                   TextWrapping="Wrap"
                                                   Text="{local:Loc WebCertIntro}" />
                                        <Grid Margin="0,0,0,8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="{local:Loc WebCertPathLabel}" Style="{StaticResource FieldLabel}" />
                                                <TextBox x:Name="CertPath" />
                                            </StackPanel>
                                            <Button Grid.Column="1"
                                                    Content="{local:Loc WebCertBrowse}"
                                                    Style="{StaticResource BtnGhost}"
                                                    VerticalAlignment="Bottom"
                                                    Margin="8,0,0,0"
                                                    Click="OnBrowseCert" />
                                        </Grid>
                                        <StackPanel Margin="0,8,0,0">
                                            <TextBlock Text="{local:Loc WebCertPasswordLabel}" Style="{StaticResource FieldLabel}" />
                                            <PasswordBox x:Name="CertPassword" />
                                        </StackPanel>
                                        <Button Content="{local:Loc WebCertGenerate}"
                                                Style="{StaticResource BtnGhost}"
                                                HorizontalAlignment="Left"
                                                Margin="0,16,0,0"
                                                Click="OnGenerateSelfSigned" />
                                    </StackPanel>
                                </Border>

                                <Border Background="#1A2331" BorderBrush="#22324A" BorderThickness="1"
                                        CornerRadius="6" Padding="12,10" Margin="0,4,0,0">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE946;" FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                                                   Foreground="{StaticResource accent}" Margin="0,0,8,0" VerticalAlignment="Top" />
                                        <TextBlock Foreground="{StaticResource text.muted}" FontSize="12" TextWrapping="Wrap"
                                                   Text="{local:Loc WebCertRestartHint}" />
                                    </StackPanel>
                                </Border>

                                <!-- ===== Toegang tot de web-interface ===== -->
                                <Border Style="{StaticResource Card}">
                                    <StackPanel>
                                        <TextBlock Text="{local:Loc WebAccessCardTitle}" Style="{StaticResource SectionHeader}" />
                                        <TextBlock Foreground="{StaticResource text.muted}" FontSize="12"
                                                   TextWrapping="Wrap"
                                                   Text="{local:Loc WebAccessCardDescription}" />

                                        <!-- Mode selector — full width so the labels for off/pin/ad don't get clipped -->
                                        <StackPanel Margin="0,16,0,0">
                                            <TextBlock Text="{local:Loc WebAccessMode}" Style="{StaticResource FieldLabel}" />
                                            <ComboBox x:Name="WebAccessMode" SelectionChanged="OnWebAccessModeChanged">
                                                <ComboBoxItem Content="{local:Loc WebAccessModeOff}" Tag="off" />
                                                <ComboBoxItem Content="{local:Loc WebAccessModePin}" Tag="pin" />
                                                <ComboBoxItem Content="{local:Loc WebAccessModeAd}" Tag="ad" />
                                            </ComboBox>
                                        </StackPanel>

                                        <!-- PIN field appears below the dropdown when mode = pin -->
                                        <StackPanel x:Name="WebAccessPinPanel" Margin="0,14,0,0" Visibility="Collapsed">
                                            <TextBlock Text="{local:Loc WebAccessPin}" Style="{StaticResource FieldLabel}" />
                                            <PasswordBox x:Name="WebAccessPin" />
                                        </StackPanel>

                                        <!-- Domain field appears below the dropdown when mode = ad -->
                                        <StackPanel x:Name="WebAccessAdPanel" Margin="0,14,0,0" Visibility="Collapsed">
                                            <TextBlock Text="{local:Loc WebAccessDomain}" Style="{StaticResource FieldLabel}" />
                                            <TextBox x:Name="WebAccessDomain" />
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </StackPanel>

                            <!-- ============================ Audit ============================ -->
                            <StackPanel x:Name="AuditPanel" Visibility="Collapsed">
                                <TextBlock Text="{local:Loc AuditPageTitle}" Style="{StaticResource PageTitle}" />
                                <TextBlock Text="{local:Loc AuditPageSubtitle}" Style="{StaticResource PageSubtitle}" />

                                <!-- ============== Syslog forwarding ============== -->
                                <Border Style="{StaticResource Card}">
                                    <StackPanel>
                                        <Grid>
                                            <StackPanel>
                                                <TextBlock Text="{local:Loc AuditCardForwarding}" Style="{StaticResource SectionHeader}" />
                                                <TextBlock Text="{local:Loc AuditSyslogEnabled}"
                                                           Foreground="{StaticResource text.muted}" FontSize="12"
                                                           TextWrapping="Wrap" />
                                            </StackPanel>
                                            <CheckBox x:Name="SyslogEnabled"
                                                      Style="{StaticResource ToggleSwitch}"
                                                      HorizontalAlignment="Right"
                                                      VerticalAlignment="Top" />
                                        </Grid>

                                        <Grid IsEnabled="{Binding ElementName=SyslogEnabled, Path=IsChecked}" Margin="0,16,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="20" />
                                                <ColumnDefinition Width="120" />
                                                <ColumnDefinition Width="20" />
                                                <ColumnDefinition Width="140" />
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="14" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="14" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>

                                            <StackPanel Grid.Row="0" Grid.Column="0">
                                                <TextBlock Text="{local:Loc AuditSyslogHost}" Style="{StaticResource FieldLabel}" />
                                                <TextBox x:Name="SyslogHost" />
                                            </StackPanel>
                                            <StackPanel Grid.Row="0" Grid.Column="2">
                                                <TextBlock Text="{local:Loc AuditSyslogPort}" Style="{StaticResource FieldLabel}" />
                                                <TextBox x:Name="SyslogPort" />
                                            </StackPanel>
                                            <StackPanel Grid.Row="0" Grid.Column="4">
                                                <TextBlock Text="{local:Loc AuditSyslogProtocol}" Style="{StaticResource FieldLabel}" />
                                                <ComboBox x:Name="SyslogProtocol">
                                                    <ComboBoxItem Content="UDP" Tag="udp" />
                                                    <ComboBoxItem Content="TCP" Tag="tcp" />
                                                </ComboBox>
                                            </StackPanel>

                                            <StackPanel Grid.Row="2" Grid.Column="0">
                                                <TextBlock Text="{local:Loc AuditSyslogAppName}" Style="{StaticResource FieldLabel}" />
                                                <TextBox x:Name="SyslogAppName" />
                                            </StackPanel>
                                            <StackPanel Grid.Row="2" Grid.Column="2">
                                                <TextBlock Text="{local:Loc AuditSyslogFacility}" Style="{StaticResource FieldLabel}" />
                                                <TextBox x:Name="SyslogFacility" />
                                            </StackPanel>

                                            <Button Grid.Row="4" Grid.Column="0"
                                                    HorizontalAlignment="Left"
                                                    Content="{local:Loc AuditSyslogTest}"
                                                    Style="{StaticResource BtnGhost}"
                                                    Click="OnSyslogTest" />
                                            <TextBlock Grid.Row="4" Grid.Column="2" Grid.ColumnSpan="3"
                                                       x:Name="SyslogTestResult"
                                                       VerticalAlignment="Center"
                                                       FontSize="12"
                                                       TextWrapping="Wrap" />
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <!-- ============== Audit-log viewer ============== -->
                                <Border Style="{StaticResource Card}">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="*" />
                                        </Grid.RowDefinitions>
                                        <Grid Grid.Row="0">
                                            <TextBlock Text="{local:Loc AuditCardRecent}" Style="{StaticResource SectionHeader}" />
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                                <Button Content="{local:Loc AuditRefresh}" Style="{StaticResource BtnGhost}" Click="OnAuditRefresh" Margin="0,0,8,0" />
                                                <Button Content="{local:Loc AuditExportCsv}" Style="{StaticResource BtnGhost}" Click="OnAuditExport" />
                                            </StackPanel>
                                        </Grid>
                                        <TextBlock x:Name="AuditPath" Grid.Row="1"
                                                   Foreground="{StaticResource text.dim}" FontSize="11"
                                                   Margin="0,0,0,8" TextTrimming="CharacterEllipsis" />
                                        <DataGrid x:Name="AuditGrid"
                                                  Grid.Row="2"
                                                  Height="380"
                                                  IsReadOnly="True"
                                                  AutoGenerateColumns="False"
                                                  HeadersVisibility="Column">
                                            <DataGrid.Columns>
                                                <DataGridTextColumn Binding="{Binding TimestampDisplay}" Width="170">
                                                    <DataGridTextColumn.Header><TextBlock Text="{local:Loc AuditHeaderTimestamp}" /></DataGridTextColumn.Header>
                                                </DataGridTextColumn>
                                                <DataGridTextColumn Binding="{Binding Type}" Width="120">
                                                    <DataGridTextColumn.Header><TextBlock Text="{local:Loc AuditHeaderType}" /></DataGridTextColumn.Header>
                                                </DataGridTextColumn>
                                                <DataGridTextColumn Binding="{Binding Slot}" Width="60">
                                                    <DataGridTextColumn.Header><TextBlock Text="{local:Loc AuditHeaderSlot}" /></DataGridTextColumn.Header>
                                                </DataGridTextColumn>
                                                <DataGridTextColumn Binding="{Binding Label}" Width="160">
                                                    <DataGridTextColumn.Header><TextBlock Text="{local:Loc AuditHeaderLabel}" /></DataGridTextColumn.Header>
                                                </DataGridTextColumn>
                                                <DataGridTextColumn Binding="{Binding Source}" Width="160">
                                                    <DataGridTextColumn.Header><TextBlock Text="{local:Loc AuditHeaderSource}" /></DataGridTextColumn.Header>
                                                </DataGridTextColumn>
                                                <DataGridTextColumn Binding="{Binding Detail}" Width="*">
                                                    <DataGridTextColumn.Header><TextBlock Text="{local:Loc AuditHeaderDetail}" /></DataGridTextColumn.Header>
                                                </DataGridTextColumn>
                                            </DataGrid.Columns>
                                        </DataGrid>
                                    </Grid>
                                </Border>
                            </StackPanel>

                            <!-- ============================ Beheerder ============================ -->
                            <StackPanel x:Name="AdminPanel" Visibility="Collapsed">
                                <TextBlock Text="{local:Loc AdminPageTitle}" Style="{StaticResource PageTitle}" />
                                <TextBlock Text="{local:Loc AdminPageSubtitle}" Style="{StaticResource PageSubtitle}" />

                                <Border Style="{StaticResource Card}">
                                    <StackPanel>
                                        <TextBlock Text="{local:Loc AdminCardPin}" Style="{StaticResource SectionHeader}" />
                                        <TextBlock Foreground="{StaticResource text.muted}" FontSize="12" Margin="0,0,0,12"
                                                   TextWrapping="Wrap"
                                                   Text="{local:Loc AdminPinDescription}" />
                                        <Button Content="{local:Loc AdminPinChangeButton}" Style="{StaticResource BtnGhost}"
                                                HorizontalAlignment="Left" Click="OnChangeAdminPin" />
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource Card}">
                                    <StackPanel>
                                        <TextBlock Text="{local:Loc AdminCardLanguage}" Style="{StaticResource SectionHeader}" />
                                        <!-- Display name lives on LanguageChoice and is intentionally
                                             rendered in the language's own native script (Deutsch,
                                             Français, Español, ...) so a non-Dutch admin can find
                                             their own tongue regardless of the current UI language. -->
                                        <ComboBox x:Name="LanguageBox"
                                                  DisplayMemberPath="DisplayName"
                                                  SelectedValuePath="Code"
                                                  Margin="0,0,0,8"
                                                  HorizontalAlignment="Left"
                                                  MinWidth="200" />
                                        <TextBlock Foreground="{StaticResource text.muted}" FontSize="12"
                                                   Text="{local:Loc AdminLanguageHint}" />
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource Card}">
                                    <StackPanel>
                                        <Grid Margin="0,0,0,12">
                                            <StackPanel>
                                                <TextBlock Text="{local:Loc AdminCardIdentity}" Style="{StaticResource SectionHeader}" />
                                                <TextBlock Foreground="{StaticResource text.muted}" FontSize="12"
                                                           TextWrapping="Wrap"
                                                           Text="{local:Loc AdminIdentityDescription}" />
                                            </StackPanel>
                                            <CheckBox x:Name="UseActiveDirectory"
                                                      Style="{StaticResource ToggleSwitch}"
                                                      HorizontalAlignment="Right"
                                                      VerticalAlignment="Top" />
                                        </Grid>
                                        <TextBlock Text="{local:Loc AdminDomainLabel}" Style="{StaticResource FieldLabel}" />
                                        <TextBox x:Name="AuthDomain" />
                                        <TextBlock Foreground="{StaticResource text.muted}" FontSize="12" Margin="0,6,0,0"
                                                   TextWrapping="Wrap"
                                                   Text="{local:Loc AdminDomainHint}" />
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource Card}">
                                    <StackPanel>
                                        <TextBlock Text="{local:Loc AdminCardHelp}" Style="{StaticResource SectionHeader}" />
                                        <TextBlock Foreground="{StaticResource text.muted}" FontSize="12" Margin="0,0,0,12"
                                                   TextWrapping="Wrap"
                                                   Text="{local:Loc AdminHelpDescription}" />
                                        <Button Content="{local:Loc AdminHelpOpen}" Style="{StaticResource BtnGhost}"
                                                HorizontalAlignment="Left" Click="OnOpenHelp" />
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource Card}">
                                    <Grid>
                                        <StackPanel>
                                            <TextBlock Text="{local:Loc AdminCardKiosk}" Style="{StaticResource SectionHeader}" />
                                            <TextBlock Foreground="{StaticResource text.muted}" FontSize="12"
                                                       TextWrapping="Wrap"
                                                       Text="{local:Loc AdminKioskDescription}" />
                                        </StackPanel>
                                        <CheckBox x:Name="KioskEnabled"
                                                  Style="{StaticResource ToggleSwitch}"
                                                  HorizontalAlignment="Right"
                                                  VerticalAlignment="Top" />
                                    </Grid>
                                </Border>
                            </StackPanel>

                            <!-- ============================ About ============================ -->
                            <StackPanel x:Name="AboutPanel" Visibility="Collapsed">
                                <TextBlock Text="{local:Loc AboutPageTitle}" Style="{StaticResource PageTitle}" />
                                <TextBlock Text="{local:Loc AboutPageSubtitle}" Style="{StaticResource PageSubtitle}" />

                                <!-- ===== Product info ===== -->
                                <Border Style="{StaticResource Card}">
                                    <StackPanel>
                                        <TextBlock Text="{local:Loc AboutCardProduct}" Style="{StaticResource SectionHeader}" />
                                        <Grid Margin="0,12,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="160" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>
                                            <TextBlock Grid.Row="0" Grid.Column="0" Text="{local:Loc AboutVersionLabel}"
                                                       Foreground="{StaticResource text.muted}" FontSize="13" Margin="0,0,0,8" />
                                            <TextBlock Grid.Row="0" Grid.Column="1" x:Name="AboutVersionValue"
                                                       Text="" FontSize="13" Margin="0,0,0,8" />
                                            <TextBlock Grid.Row="1" Grid.Column="0" Text="{local:Loc AboutPublisherLabel}"
                                                       Foreground="{StaticResource text.muted}" FontSize="13" Margin="0,0,0,8" />
                                            <TextBlock Grid.Row="1" Grid.Column="1" Text="IDIS Nederland BV"
                                                       FontSize="13" Margin="0,0,0,8" />
                                            <TextBlock Grid.Row="2" Grid.Column="0" Text="{local:Loc AboutCopyrightLabel}"
                                                       Foreground="{StaticResource text.muted}" FontSize="13" Margin="0,0,0,8" />
                                            <TextBlock Grid.Row="2" Grid.Column="1" Text="© 2026 IDIS Nederland BV. All rights reserved."
                                                       FontSize="13" Margin="0,0,0,8" />
                                            <TextBlock Grid.Row="3" Grid.Column="0" Text="{local:Loc AboutWebsiteLabel}"
                                                       Foreground="{StaticResource text.muted}" FontSize="13" />
                                            <TextBlock Grid.Row="3" Grid.Column="1" FontSize="13">
                                                <Hyperlink NavigateUri="https://www.idisglobal.solutions"
                                                           RequestNavigate="OnAboutOpenLink"
                                                           Foreground="{StaticResource accent}"
                                                           TextDecorations="None">https://www.idisglobal.solutions</Hyperlink>
                                            </TextBlock>
                                        </Grid>
                                        <TextBlock Foreground="{StaticResource text.muted}" FontSize="12" Margin="0,16,0,0"
                                                   TextWrapping="Wrap"
                                                   Text="{local:Loc AboutDescription}" />
                                    </StackPanel>
                                </Border>

                                <!-- ===== Integrations / proprietary deps ===== -->
                                <Border Style="{StaticResource Card}">
                                    <StackPanel>
                                        <TextBlock Text="{local:Loc AboutCardLicensesIntegrations}" Style="{StaticResource SectionHeader}" />
                                        <StackPanel Margin="0,12,0,0">
                                            <Grid Margin="0,0,0,6">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" FontSize="13"
                                                           Text="IDIS Direct IP NVR's" />
                                                <TextBlock Grid.Column="1" Foreground="{StaticResource text.muted}" FontSize="12"
                                                           Text="© IDIS Co., Ltd. — proprietary" />
                                            </Grid>
                                            <Grid Margin="0,0,0,6">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" FontSize="13"
                                                           Text="SDL2" />
                                                <TextBlock Grid.Column="1" Foreground="{StaticResource text.muted}" FontSize="12"
                                                           Text="zlib license — sdl-libsdl.org" />
                                            </Grid>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" FontSize="13"
                                                           Text="Authenticode signing certificate" />
                                                <TextBlock Grid.Column="1" Foreground="{StaticResource text.muted}" FontSize="12"
                                                           Text="Sectigo Public Code Signing CA R36 (EV)" />
                                            </Grid>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>

                                <!-- ===== Open-source components ===== -->
                                <Border Style="{StaticResource Card}">
                                    <StackPanel>
                                        <TextBlock Text="{local:Loc AboutCardLicensesThird}" Style="{StaticResource SectionHeader}" />
                                        <StackPanel Margin="0,12,0,0">
                                            <Grid Margin="0,0,0,6">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" FontSize="13"
                                                           Text=".NET 9 (Microsoft.WindowsDesktop.App)" />
                                                <TextBlock Grid.Column="1" Foreground="{StaticResource text.muted}" FontSize="12"
                                                           Text="MIT — Microsoft" />
                                            </Grid>
                                            <Grid Margin="0,0,0,6">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" FontSize="13"
                                                           Text="ASP.NET Core 9 (Kestrel + Razor Pages, used by WebHost)" />
                                                <TextBlock Grid.Column="1" Foreground="{StaticResource text.muted}" FontSize="12"
                                                           Text="MIT — Microsoft" />
                                            </Grid>
                                            <Grid Margin="0,0,0,6">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" FontSize="13"
                                                           Text="Microsoft.Extensions.Configuration / Hosting / WindowsServices" />
                                                <TextBlock Grid.Column="1" Foreground="{StaticResource text.muted}" FontSize="12"
                                                           Text="MIT — Microsoft" />
                                            </Grid>
                                            <Grid Margin="0,0,0,6">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" FontSize="13"
                                                           Text="System.Security.Cryptography.ProtectedData" />
                                                <TextBlock Grid.Column="1" Foreground="{StaticResource text.muted}" FontSize="12"
                                                           Text="MIT — Microsoft" />
                                            </Grid>
                                            <Grid Margin="0,0,0,6">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" FontSize="13"
                                                           Text="WiX Toolset 5 (Util, Firewall, UI extensions)" />
                                                <TextBlock Grid.Column="1" Foreground="{StaticResource text.muted}" FontSize="12"
                                                           Text="MS-RL — WiX Toolset Foundation" />
                                            </Grid>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" FontSize="13"
                                                           Text="Segoe Fluent Icons / Segoe MDL2 Assets" />
                                                <TextBlock Grid.Column="1" Foreground="{StaticResource text.muted}" FontSize="12"
                                                           Text="Microsoft — Windows 10/11 system font" />
                                            </Grid>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>

                                <!-- ===== System capabilities (v2.0 prerequisite P2) ===== -->
                                <Border Style="{StaticResource Card}">
                                    <StackPanel>
                                        <Grid>
                                            <TextBlock Text="{local:Loc AboutCardSystemCapabilities}" Style="{StaticResource SectionHeader}" />
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                                <Button x:Name="AboutCapsBenchmarkBtn"
                                                        Content="{local:Loc AboutCapsBenchmarkRun}"
                                                        Style="{StaticResource BtnGhost}"
                                                        Margin="0,0,8,0"
                                                        Click="OnAboutCapsBenchmark" />
                                                <Button x:Name="AboutCapsRefreshBtn"
                                                        Content="{local:Loc AboutCapsRefreshButton}"
                                                        Style="{StaticResource BtnGhost}"
                                                        Click="OnAboutCapsRefresh" />
                                            </StackPanel>
                                        </Grid>
                                        <TextBlock x:Name="AboutCapsStatus"
                                                   Foreground="{StaticResource text.muted}" FontSize="13" Margin="0,12,0,8"
                                                   Text="{local:Loc AboutCapsProbing}" />
                                        <StackPanel x:Name="AboutCapsContent" />
                                    </StackPanel>
                                </Border>

                                <!-- ===== Bug report ===== -->
                                <Border Style="{StaticResource Card}">
                                    <StackPanel>
                                        <TextBlock Text="{local:Loc AboutCardBugReport}" Style="{StaticResource SectionHeader}" />
                                        <TextBlock Foreground="{StaticResource text.muted}" FontSize="13" Margin="0,12,0,12"
                                                   TextWrapping="Wrap"
                                                   Text="{local:Loc AboutBugReportIntro}" />
                                        <Button x:Name="AboutBugReportBtn"
                                                Content="{local:Loc AboutBugReportButton}"
                                                Style="{StaticResource BtnGhost}"
                                                Click="OnAboutBugReport"
                                                HorizontalAlignment="Left" />
                                        <TextBlock Foreground="{StaticResource text.dim}" FontSize="11" Margin="0,8,0,0"
                                                   Text="support@bnl.idisglobal.com" />
                                    </StackPanel>
                                </Border>
                            </StackPanel>

                        </Grid>
                    </ScrollViewer>

                    <!-- ============== Action bar ============== -->
                    <Border Grid.Row="1" BorderBrush="{StaticResource border}" BorderThickness="0,1,0,0" Padding="36,16">
                        <Grid>
                            <TextBlock x:Name="StatusLine"
                                       Foreground="{StaticResource amber}"
                                       VerticalAlignment="Center" />
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Content="{local:Loc SetupCancel}" Style="{StaticResource BtnGhost}" Click="OnCancel" Margin="0,0,10,0" />
                                <Button Content="{local:Loc SetupApply}"  Style="{StaticResource BtnGhost}" Click="OnApply" Margin="0,0,10,0" />
                                <Button Content="{local:Loc SetupSave}"  Style="{StaticResource BtnPrimary}" Click="OnSave" />
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>
