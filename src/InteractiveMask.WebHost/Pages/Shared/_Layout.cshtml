@inject WebSettingsProvider Settings
@{
    var lang = Settings.Current.Language;
    var t = Translations.For(lang);
}
<!DOCTYPE html>
<html lang="@lang">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>InteractiveMask</title>
    <link rel="icon" type="image/x-icon" href="~/favicon.ico" />
    <link rel="icon" type="image/png" sizes="32x32" href="~/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="~/favicon-16x16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="~/apple-touch-icon.png" />
    <link rel="stylesheet" href="~/site.css" />
</head>
<body>
    <header class="topbar">
        <div class="brand">InteractiveMask</div>
        <div class="conn">
            <span id="conn-dot" class="dot dot-grey"></span>
            <span id="conn-text">@t.WaitingForDisplay</span>
            <button id="logout-btn" class="logout-btn" type="button" hidden>@t.Logout</button>
        </div>
    </header>
    <main>
        @RenderBody()
    </main>
</body>
</html>
