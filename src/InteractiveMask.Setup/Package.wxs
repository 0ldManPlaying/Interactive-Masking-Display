<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:util="http://wixtoolset.org/schemas/v4/wxs/util"
     xmlns:fire="http://wixtoolset.org/schemas/v4/wxs/firewall"
     xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui">

    <!-- 64-bit MSI: all auto-harvested components live under ProgramFiles64Folder.
         The wixproj sets InstallerPlatform=x64 which is the WiX 5 way to mark the
         whole package as 64-bit and avoid ICE80 violations on harvested files. -->
    <Package Name="InteractiveMask"
             Manufacturer="IDIS Nederland BV"
             Version="$(ProductVersion)"
             UpgradeCode="A2C0BC42-1B12-4C96-9D3E-7F4A4B27E901"
             Scope="perMachine"
             Compressed="yes">

        <SummaryInformation Description="InteractiveMask kiosk + WebHost service" />
        <MediaTemplate EmbedCab="yes" />

        <!-- Major-upgrade: a newer version uninstalls the old one in-place. -->
        <MajorUpgrade DowngradeErrorMessage="Een nieuwere versie van [ProductName] is al geinstalleerd." />

        <!-- ============== Layout ============== -->
        <StandardDirectory Id="ProgramFiles64Folder">
            <Directory Id="INSTALLFOLDER" Name="InteractiveMask">
                <Directory Id="DisplayFolder" Name="Display" />
                <Directory Id="ServiceFolder" Name="Service" />
            </Directory>
        </StandardDirectory>
        <StandardDirectory Id="ProgramMenuFolder">
            <Directory Id="AppShortcutFolder" Name="InteractiveMask" />
        </StandardDirectory>
        <StandardDirectory Id="DesktopFolder" />

        <!-- Window-icon resource referenced by both shortcuts. The .ico lives
             inside the Display project and is also used as the EXE icon. -->
        <Icon Id="AppIco" SourceFile="..\InteractiveMask.Display\app.ico" />
        <Property Id="ARPPRODUCTICON" Value="AppIco" />

        <!-- File harvest paths are resolved at MSBuild time relative to the wixproj.
             build-installer.ps1 always publishes into ..\..\build\publish\{Display,WebHost}
             which is what we hardcode here. The named BindPath in the wixproj lets
             linker-resolved File@Source attributes use the !(bindpath.X) form. -->

        <!-- ============== Display: harvested file set ============== -->
        <ComponentGroup Id="DisplayFiles" Directory="DisplayFolder">
            <!-- Display.exe needs an explicit File@Id ("DisplayExe") so the
                 launch-after-install custom action and the shortcuts can refer to
                 it via [#DisplayExe]. The rest of the publish folder is harvested. -->
            <Files Include="..\..\build\publish\Display\**">
                <Exclude Files="..\..\build\publish\Display\InteractiveMask.Display.exe" />
            </Files>
        </ComponentGroup>

        <Component Id="DisplayExeComponent" Directory="DisplayFolder" Guid="C73D8A91-1F4B-4F1B-9D5E-0AE5E4B1C8FA">
            <File Id="DisplayExe"
                  Source="..\..\build\publish\Display\InteractiveMask.Display.exe"
                  KeyPath="yes" />
        </Component>

        <!-- ============== WebHost: harvested file set + service registration ============== -->
        <ComponentGroup Id="WebHostFiles" Directory="ServiceFolder">
            <Files Include="..\..\build\publish\WebHost\**">
                <!-- The exe gets a separate component below so we can attach
                     ServiceInstall + ServiceControl to it. -->
                <Exclude Files="..\..\build\publish\WebHost\InteractiveMask.WebHost.exe" />
            </Files>
        </ComponentGroup>

        <Component Id="WebHostService" Directory="ServiceFolder" Guid="0E2A9B5C-4D3F-4E2C-9E0A-2D7E0E7B7F11">
            <File Id="WebHostExe"
                  Source="..\..\build\publish\WebHost\InteractiveMask.WebHost.exe"
                  KeyPath="yes" />

            <ServiceInstall Id="WebHostSvcInstall"
                            Name="InteractiveMaskWebHost"
                            DisplayName="InteractiveMask WebHost"
                            Description="Provides the local browser bediening for the InteractiveMask kiosk."
                            Type="ownProcess"
                            Start="auto"
                            ErrorControl="normal"
                            Vital="yes"
                            Account="LocalSystem" />
            <ServiceControl Id="WebHostSvcControl"
                            Name="InteractiveMaskWebHost"
                            Start="install"
                            Stop="both"
                            Remove="uninstall"
                            Wait="yes" />

            <!-- Open the LAN port the WebHost listens on (matches appsettings.json). -->
            <fire:FirewallException Id="WebHostFirewallTcp"
                                    Name="InteractiveMask WebHost"
                                    Port="8080"
                                    Protocol="tcp"
                                    Scope="any"
                                    Profile="all" />
        </Component>

        <!-- ============== Start-menu shortcut ============== -->
        <Component Id="DisplayShortcut" Directory="AppShortcutFolder" Guid="A56B5C3F-2C2C-4E91-9D49-1A6F8B7C81FF">
            <Shortcut Id="DisplayStartMenuShortcut"
                      Name="InteractiveMask Display"
                      Description="Start de kiosk-applicatie"
                      Target="[DisplayFolder]InteractiveMask.Display.exe"
                      WorkingDirectory="DisplayFolder"
                      Icon="AppIco" />
            <RemoveFolder Id="RemoveAppShortcutFolder" Directory="AppShortcutFolder" On="uninstall" />
            <RegistryValue Root="HKCU"
                           Key="Software\InteractiveMask"
                           Name="installed"
                           Type="integer"
                           Value="1"
                           KeyPath="yes" />
        </Component>

        <!-- ============== Desktop shortcut ============== -->
        <Component Id="DesktopShortcut" Directory="DesktopFolder" Guid="B62C9D1A-3E33-4F87-A12B-5D7C0A0B5C22">
            <Shortcut Id="DisplayDesktopShortcut"
                      Name="InteractiveMask"
                      Description="Start de kiosk-applicatie"
                      Target="[DisplayFolder]InteractiveMask.Display.exe"
                      WorkingDirectory="DisplayFolder"
                      Icon="AppIco" />
            <RegistryValue Root="HKCU"
                           Key="Software\InteractiveMask"
                           Name="desktop_shortcut"
                           Type="integer"
                           Value="1"
                           KeyPath="yes" />
        </Component>

        <!-- ============== Launch-after-install option ============== -->
        <!-- WixUI_InstallDir gives us a standard install wizard with the optional
             "launch after finish" checkbox slot exposed via WIXUI_EXITDIALOG*
             properties. The custom action below fires when the user ticks the
             checkbox and clicks Finish. -->
        <ui:WixUI Id="WixUI_InstallDir" />
        <Property Id="WIXUI_INSTALLDIR" Value="INSTALLFOLDER" />
        <Property Id="WIXUI_EXITDIALOGOPTIONALCHECKBOX" Value="1" />
        <Property Id="WIXUI_EXITDIALOGOPTIONALCHECKBOXTEXT" Value="InteractiveMask nu starten" />
        <Property Id="WixShellExecTarget" Value="[#DisplayExe]" />
        <CustomAction Id="LaunchApplication"
                      DllEntry="WixShellExec"
                      Impersonate="yes"
                      BinaryRef="Wix4UtilCA_X64" />

        <!-- Hook the custom action to the Finish button. Fires only on a fresh
             install (not on uninstall or repair) and only when the user kept
             the optional checkbox ticked. -->
        <UI>
            <Publish Dialog="ExitDialog"
                     Control="Finish"
                     Event="DoAction"
                     Value="LaunchApplication"
                     Condition="WIXUI_EXITDIALOGOPTIONALCHECKBOX = 1 and NOT Installed" />
        </UI>

        <!-- ============== Feature tree ============== -->
        <Feature Id="DisplayFeature" Title="Display kiosk" Level="1">
            <ComponentGroupRef Id="DisplayFiles" />
            <ComponentRef Id="DisplayExeComponent" />
            <ComponentRef Id="DisplayShortcut" />
            <ComponentRef Id="DesktopShortcut" />
        </Feature>

        <Feature Id="WebHostFeature" Title="WebHost service" Level="1">
            <ComponentGroupRef Id="WebHostFiles" />
            <ComponentRef Id="WebHostService" />
        </Feature>

    </Package>
</Wix>
